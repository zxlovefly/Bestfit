page { background: #F2F4F7; font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif; }
.header { padding: 40rpx 36rpx 24rpx; opacity: 0; animation: fi 0.4s ease forwards; }
.h-title { font-size: 44rpx; font-weight: 800; color: #1A1A2E; display: block; }
.h-sub { font-size: 26rpx; color: #999; margin-top: 8rpx; display: block; }
@keyframes fi { from { opacity: 0; transform: translateY(16rpx); } to { opacity: 1; transform: none; } }

/* overview */
.overview { margin: 16rpx 28rpx 0; opacity: 0; animation: fi 0.4s ease forwards 0.05s; }
.ov-row { display: flex; gap: 16rpx; }
.ov-card { flex: 1; background: #fff; border-radius: 24rpx; padding: 28rpx 16rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04); }
.ov-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.ov-val { font-size: 38rpx; font-weight: 800; color: #1A1A2E; line-height: 1; }
.ov-val.up { color: #FF6B6B; }
.ov-val.down { color: #34C759; }
.ov-val.flat { color: #999; }
.ov-label { font-size: 20rpx; color: #999; margin-top: 8rpx; text-align: center; }
.ov-summary { margin-top: 16rpx; background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; text-align: center; }
.ov-summary text { font-size: 24rpx; color: #666; }

/* 身体数据概览 */
.body-overview { margin: 24rpx 28rpx 0; opacity: 0; animation: fi 0.4s ease forwards 0.08s; }
.body-overview .sec-title { font-size: 30rpx; font-weight: 700; color: #1A1A2E; margin-bottom: 16rpx; display: block; }
.bo-row { display: flex; gap: 16rpx; }
.bo-card { flex: 1; background: #fff; border-radius: 24rpx; padding: 24rpx 12rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04); }
.bo-icon { font-size: 32rpx; margin-bottom: 8rpx; }
.bo-val { font-size: 34rpx; font-weight: 800; color: #1A1A2E; line-height: 1; }
.bo-unit { font-size: 22rpx; font-weight: 500; color: #999; margin-left: 2rpx; }
.bo-label { font-size: 20rpx; color: #999; margin-top: 8rpx; }

/* empty */
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: #999; text-align: center; }

/* chart */
.chart-sec { margin: 32rpx 28rpx 0; opacity: 0; animation: fi 0.4s ease forwards 0.1s; }
.chart-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.chart-title { font-size: 30rpx; font-weight: 700; color: #1A1A2E; }
.range-tabs { display: flex; background: #F0F0F5; border-radius: 12rpx; padding: 4rpx; }
.rt { padding: 8rpx 20rpx; font-size: 22rpx; color: #999; border-radius: 10rpx; font-weight: 500; }
.rt.on { background: #fff; color: #FB7299; font-weight: 600; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.chart-box { background: #fff; border-radius: 28rpx; padding: 24rpx 12rpx 16rpx; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04); }
.stats-chart { width: 100%; height: 400rpx; }

/* list */
.list-sec { margin: 32rpx 28rpx 0; opacity: 0; animation: fi 0.4s ease forwards 0.15s; }
.sec-title { font-size: 34rpx; font-weight: 700; color: #1A1A2E; margin-bottom: 20rpx; display: block; }
.list-card { background: #fff; border-radius: 24rpx; overflow: hidden; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04); }
.list-item { display: flex; flex-direction: column; border-bottom: 1rpx solid #F5F5F5; }
.list-item:last-child { border-bottom: none; }

.li-row { display: flex; align-items: center; padding: 24rpx 28rpx; }
.li-left { width: 180rpx; }
.li-date { font-size: 26rpx; font-weight: 600; color: #1A1A2E; display: block; }
.li-weekday { font-size: 20rpx; color: #BDBDBD; display: block; margin-top: 4rpx; }
.li-center { flex: 1; display: flex; align-items: baseline; justify-content: center; }
.li-weight { font-size: 36rpx; font-weight: 800; color: #1A1A2E; }
.li-unit { font-size: 22rpx; color: #999; margin-left: 4rpx; }
.li-right { width: 120rpx; display: flex; flex-direction: column; align-items: flex-end; }
.li-bmi { font-size: 26rpx; font-weight: 600; }
.li-bmi.normal { color: #34C759; }
.li-bmi.overweight { color: #FF9800; }
.li-bmi.underweight { color: #5C6BC0; }
.li-bmi.obese { color: #FF6B6B; }
.li-bmi-label { font-size: 20rpx; color: #BDBDBD; margin-top: 2rpx; }

/* 变化列 —— 始终显示，保持对齐 */
.li-change {
  width: 120rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* 增长 = 红色 */
.ch-up {
  font-size: 26rpx;
  font-weight: 700;
  color: #FF6B6B;
  background: #FFF0F0;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

/* 下降 = 绿色 */
.ch-down {
  font-size: 26rpx;
  font-weight: 700;
  color: #34C759;
  background: #EDF9F0;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

/* 持平 / 无数据 = 灰色 */
.ch-flat {
  font-size: 26rpx;
  font-weight: 500;
  color: #BDBDBD;
  padding: 4rpx 14rpx;
}

/* 身体数据标签行 */
.li-body { display: flex; gap: 12rpx; padding: 0 28rpx 18rpx; flex-wrap: wrap; }
.li-body-tag { font-size: 20rpx; color: #888; background: #F6F7F9; padding: 4rpx 16rpx; border-radius: 12rpx; white-space: nowrap; }

.spacer { height: 80rpx; }
