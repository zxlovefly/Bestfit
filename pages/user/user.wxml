<scroll-view scroll-y class="user-page" style="height:100vh">

<!-- ===== 头像放大预览 ===== -->
<view class="avatar-preview-modal" wx:if="{{showAvatarPreview}}">
  <view class="preview-overlay" bindtap="closeAvatarPreview"></view>
  <view class="preview-close" bindtap="closeAvatarPreview">
    <text class="preview-close-icon">✕</text>
  </view>
  <view class="preview-body">
    <view class="preview-avatar-area">
      <view class="preview-avatar-glow"></view>
      <image wx:if="{{avatarType === 'custom'}}"
             class="preview-avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="preview-avatar-emoji">{{avatarEmoji}}</view>
    </view>
    <text class="preview-name">{{nickname}}</text>
    <text class="preview-tag" wx:if="{{signature}}">{{signature}}</text>
    <text class="preview-tag" wx:elif="{{gender}}">{{gender === 'female' ? '女生' : '男生'}} · 旅程第 {{journeyDays}} 天</text>
    <view class="preview-change-btn" bindtap="onChangeAvatar">
      <text class="preview-change-icon">📸</text>
      <text class="preview-change-text">更换头像</text>
    </view>
  </view>
</view>

<!-- ===== 裁剪弹窗 ===== -->
<view class="crop-modal" wx:if="{{cropVisible}}">
  <view class="crop-bg"></view>
  <canvas type="2d" id="avatarCropCanvas" class="crop-canvas-export"></canvas>
  <view class="crop-touch-layer"
    catchtouchstart="onCropTouchStart"
    catchtouchmove="onCropTouchMove"
    catchtouchend="onCropTouchEnd">
    <image wx:if="{{cropSrc}}" class="crop-img" src="{{cropSrc}}" mode="scaleToFill"
      style="left:{{imgVisL}}px;top:{{imgVisT}}px;width:{{imgVisW}}px;height:{{imgVisH}}px;" />
  </view>
  <view class="crop-circle-mask"></view>
  <view class="crop-circle-border"></view>
  <view class="crop-tip-bar">
    <text class="crop-tip">👆 拖动调整 · 双指缩放</text>
  </view>
  <view class="crop-processing-mask" wx:if="{{cropProcessing}}">
    <view class="crop-processing-spinner"></view>
    <text class="crop-processing-text">图片处理中...</text>
  </view>
  <view class="crop-btn-bar" wx:if="{{!cropProcessing}}">
    <view class="crop-btn crop-cancel" bindtap="onCropCancel">取消</view>
    <view class="crop-btn crop-ok" bindtap="onCropConfirm">使用 ✓</view>
  </view>
</view>

<!-- ===== 系统头像选择弹窗 ===== -->
<view class="modal-mask" wx:if="{{showAvatarPicker}}" bindtap="closeAvatarPicker"></view>
<view class="avatar-picker" wx:if="{{showAvatarPicker}}">
  <view class="picker-head">
    <text class="picker-title">选择头像 🎀</text>
    <text class="picker-close" bindtap="closeAvatarPicker">×</text>
  </view>
  <view class="picker-grid">
    <view class="picker-item {{selectedSysEmoji === item.emoji ? 'picker-active' : ''}}"
          wx:for="{{systemAvatars}}" wx:key="index"
          bindtap="selectSysAvatar" data-emoji="{{item.emoji}}">
      <text class="picker-emoji">{{item.emoji}}</text>
      <text class="picker-name">{{item.name}}</text>
    </view>
  </view>
  <button class="picker-confirm" bindtap="confirmSysAvatar">使用这个头像 💕</button>
</view>

<!-- ===== 用户头部 ===== -->
<view class="user-header">
  <view class="avatar-wrap" bindtap="onAvatarTap">
    <image wx:if="{{avatarType === 'custom'}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar-emoji">{{avatarEmoji}}</view>
  </view>
  <view class="user-info">
    <text class="user-name">{{nickname}}</text>
    <text class="user-tag" wx:if="{{signature}}">{{signature}}</text>
    <text class="user-tag" wx:elif="{{gender}}">{{gender === 'female' ? '女生' : '男生'}} · 旅程第 {{journeyDays}} 天</text>
    <view class="edit-hint" bindtap="goEditProfile">
      <text class="edit-hint-text">✏️ 编辑资料</text>
    </view>
  </view>
</view>

<!-- ===== 数据统计 ===== -->
<view class="stats-row">
  <view class="stat-item">
    <text class="stat-icon">📅</text>
    <text class="stat-num">{{journeyDays}}</text>
    <text class="stat-label">使用天数</text>
  </view>
  <view class="stat-item" wx:if="{{isFemale}}">
    <text class="stat-icon">🩷</text>
    <text class="stat-num">{{periodCount}}</text>
    <text class="stat-label">经期记录</text>
  </view>
  <view class="stat-item" wx:else>
    <view class="stat-placeholder"></view>
  </view>
  <view class="stat-item">
    <text class="stat-icon">🏃</text>
    <text class="stat-num">0</text>
    <text class="stat-label">运动打卡</text>
  </view>
</view>

<!-- ===== 菜单列表 ===== -->
<view class="menu-card">
  <view class="menu-item" wx:for="{{menuList}}" wx:key="index"
        bindtap="goMenu" data-name="{{item.name}}">
    <text class="menu-icon">{{item.icon}}</text>
    <text class="menu-name">{{item.name}}</text>
    <text class="menu-arrow">›</text>
  </view>
</view>

<view class="version-box">
  <text class="version-text">健康助手 v1.0.0</text>
</view>

<!-- 底部留白：悬浮条 + 导航栏 + safe-area -->
<view style="height:300rpx"></view>

</scroll-view>

<!-- ==================== 独立音乐播放器组件 ==================== -->
<music-player id="musicPlayer" bind:playlistStateChange="onPlaylistChange" />

<!-- 不再放 <tabbar>，框架通过 custom-tab-bar/ 自动注入 -->
