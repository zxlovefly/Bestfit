.user-page { min-height: 100vh; background: #FFF8F0; }

/* ===== Canvas 2D 画布 ===== */
.crop-canvas-export {
  position: absolute;
  left: 0; top: 0;
  width: 10px; height: 10px;
  opacity: 0;
  pointer-events: none;
  z-index: 0;
}

/* ===== 头像放大预览 ===== */
.avatar-preview-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
}
.preview-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(18, 12, 28, 0.94);
  animation: pvBgIn 0.3s ease forwards;
}
@keyframes pvBgIn { from { opacity: 0; } to { opacity: 1; } }

.preview-close {
  position: absolute; top: 88rpx; right: 40rpx;
  width: 76rpx; height: 76rpx; border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  z-index: 2;
  animation: pvFadeDown 0.4s ease 0.15s both;
  transition: background 0.2s;
}
.preview-close:active { background: rgba(255,255,255,0.2); }
.preview-close-icon {
  font-size: 34rpx; color: rgba(255,255,255,0.75); font-weight: 300;
  line-height: 1;
}

.preview-body {
  position: absolute; z-index: 1;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  animation: pvContentIn 0.55s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both;
}
@keyframes pvContentIn {
  from { opacity: 0; transform: scale(0.55) translateY(40rpx); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes pvFadeDown {
  from { opacity: 0; transform: translateY(-24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.preview-avatar-area {
  position: relative;
  width: 420rpx; height: 420rpx;
  margin-bottom: 52rpx;
}
.preview-avatar-glow {
  position: absolute;
  top: -50rpx; left: -50rpx;
  width: 520rpx; height: 520rpx;
  border-radius: 50%;
  background: radial-gradient(circle,
    rgba(255,180,194,0.22) 0%,
    rgba(255,180,194,0.06) 45%,
    transparent 70%);
  animation: pvGlowPulse 3s ease-in-out infinite;
}
@keyframes pvGlowPulse {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50%      { transform: scale(1.1); opacity: 1; }
}

.preview-avatar-emoji {
  position: relative;
  width: 420rpx; height: 420rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FFD6E0, #F3E8FF);
  display: flex; align-items: center; justify-content: center;
  font-size: 180rpx;
  border: 8rpx solid rgba(255,255,255,0.25);
  box-shadow: 0 24rpx 64rpx rgba(255,143,171,0.25),
              inset 0 0 40rpx rgba(255,255,255,0.15);
}
.preview-avatar-img {
  position: relative;
  width: 420rpx; height: 420rpx; border-radius: 50%;
  border: 8rpx solid rgba(255,255,255,0.25);
  box-shadow: 0 24rpx 64rpx rgba(255,143,171,0.25);
}

.preview-name {
  font-size: 48rpx; font-weight: 900; color: #fff;
  margin-bottom: 14rpx; letter-spacing: 2rpx;
  animation: pvTextIn 0.5s ease 0.22s both;
}
.preview-tag {
  font-size: 28rpx; color: rgba(255,255,255,0.45);
  margin-bottom: 60rpx; letter-spacing: 1rpx;
  animation: pvTextIn 0.5s ease 0.28s both;
}
@keyframes pvTextIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.preview-change-btn {
  display: flex; align-items: center; gap: 14rpx;
  padding: 26rpx 72rpx;
  background: linear-gradient(135deg, #FFB4C2, #FF8FAB);
  border-radius: 50rpx;
  box-shadow: 0 10rpx 36rpx rgba(255,143,171,0.45);
  animation: pvTextIn 0.5s ease 0.34s both;
  transition: transform 0.15s, box-shadow 0.15s;
}
.preview-change-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(255,143,171,0.3);
}
.preview-change-icon { font-size: 30rpx; }
.preview-change-text {
  font-size: 30rpx; font-weight: 800; color: #fff;
  letter-spacing: 3rpx;
}

/* ===== 裁剪弹窗 ===== */
.crop-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300; }
.crop-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: #F0EBE3; z-index: 0;
}

.crop-touch-layer {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 1;
}
.crop-img {
  position: absolute; display: block; pointer-events: none;
}

.crop-circle-mask {
  position: absolute; top: 50%; left: 50%;
  width: 520rpx; height: 520rpx;
  margin-left: -260rpx; margin-top: -260rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 9999rpx rgba(240, 235, 227, 0.88);
  pointer-events: none; z-index: 2;
}
.crop-circle-border {
  position: absolute; top: 50%; left: 50%;
  width: 520rpx; height: 520rpx;
  margin-left: -260rpx; margin-top: -260rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,140,170,0.55);
  pointer-events: none; z-index: 3;
  animation: circleBreath 2s ease-in-out infinite;
}
@keyframes circleBreath {
  0%, 100% { border-color: rgba(255,140,170,0.55); box-shadow: 0 0 20rpx rgba(255,182,193,0.2); }
  50%      { border-color: rgba(255,120,160,0.8); box-shadow: 0 0 40rpx rgba(255,182,193,0.35); }
}
.crop-circle-border::before, .crop-circle-border::after {
  content: ''; position: absolute; background: rgba(180,160,150,0.18);
}
.crop-circle-border::before { width: 2rpx; height: 100%; left: 50%; top: 0; margin-left: -1rpx; }
.crop-circle-border::after  { width: 100%; height: 2rpx; top: 50%; left: 0; margin-top: -1rpx; }

.crop-tip-bar {
  position: absolute; bottom: 260rpx; left: 0; right: 0;
  text-align: center; z-index: 5; pointer-events: none;
}
.crop-tip {
  font-size: 26rpx; color: #7A6E64;
  background: rgba(255,255,255,0.85); padding: 12rpx 32rpx;
  border-radius: 30rpx; letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.crop-processing-mask {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: rgba(240,235,227,0.6);
  z-index: 20;
}
.crop-processing-spinner {
  width: 64rpx; height: 64rpx;
  border: 6rpx solid rgba(255,140,170,0.2);
  border-top-color: #FF8FAB;
  border-radius: 50%;
  animation: spinRotate 0.8s linear infinite;
  margin-bottom: 24rpx;
}
@keyframes spinRotate { to { transform: rotate(360deg); } }
.crop-processing-text {
  font-size: 28rpx; color: #7A6E64; font-weight: 600;
}

.crop-btn-bar {
  position: absolute; bottom: 100rpx; left: 0; right: 0;
  display: flex; justify-content: center; gap: 60rpx;
  z-index: 10;
}
.crop-btn {
  padding: 22rpx 64rpx; border-radius: 44rpx;
  font-size: 30rpx; font-weight: 700; text-align: center;
  min-width: 180rpx; transition: transform 0.15s;
}
.crop-btn:active { transform: scale(0.93); }
.crop-cancel {
  background: rgba(120,100,90,0.08); color: #7A6E64;
  border: 2rpx solid rgba(120,100,90,0.18);
}
.crop-ok {
  background: linear-gradient(135deg, #FFB4C2, #FF8FAB); color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255,143,171,0.4);
}

/* ===== 系统头像选择弹窗 ===== */
.modal-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.4); z-index: 88;
}
.avatar-picker {
  position: fixed; bottom: 0; left: 0; width: 100%;
  background: #fff; border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx; box-sizing: border-box; z-index: 89;
  max-height: 80vh;
}
.picker-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 32rpx;
}
.picker-title { font-size: 36rpx; font-weight: 900; color: #2D2B41; }
.picker-close { font-size: 48rpx; color: #A8A5B8; padding: 0 16rpx; }
.picker-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  max-height: 520rpx; overflow-y: auto; padding-bottom: 16rpx;
}
.picker-item {
  width: calc((100% - 80rpx) / 6);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 16rpx 0;
  border-radius: 24rpx; border: 3rpx solid #F0EDF5;
  background: #FAFAFE; transition: all 0.2s;
}
.picker-item.picker-active {
  border-color: #FFB4C2; background: #FFF0F5;
  box-shadow: 0 4rpx 16rpx rgba(255,143,171,0.25);
  transform: scale(1.08);
}
.picker-emoji { font-size: 52rpx; line-height: 1.2; }
.picker-name { font-size: 18rpx; color: #A8A5B8; margin-top: 4rpx; }
.picker-confirm {
  width: 100% !important; height: 88rpx; margin-top: 24rpx;
  background: linear-gradient(135deg, #FFB4C2, #FF8FAB) !important;
  color: #fff !important; font-size: 30rpx; font-weight: 800;
  border-radius: 44rpx; border: none;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(255,143,171,0.3);
}
.picker-confirm:active { transform: scale(0.97); }

/* ===== 头部 ===== */
.user-header { display: flex; align-items: center; gap: 28rpx; padding: 80rpx 40rpx 48rpx; }
.avatar-wrap {
  position: relative; flex-shrink: 0; width: 140rpx; height: 140rpx;
  transition: transform 0.15s;
}
.avatar-wrap:active { transform: scale(0.93); }
.avatar-emoji {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FFD6E0, #F3E8FF);
  display: flex; align-items: center; justify-content: center;
  font-size: 72rpx; border: 6rpx solid #fff;
  box-shadow: 0 8rpx 28rpx rgba(255,143,171,0.2);
}
.avatar-img {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  border: 6rpx solid #fff; box-shadow: 0 8rpx 28rpx rgba(255,143,171,0.2);
}

.user-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.user-name { font-size: 40rpx; font-weight: 900; color: #2D2B41; display: block; }
.user-tag { font-size: 26rpx; color: #A8A5B8; display: block; }
.edit-hint {
  display: inline-flex; align-items: center; margin-top: 8rpx;
  background: #FFF5F7; border: 2rpx solid #FFE0EA;
  border-radius: 20rpx; padding: 8rpx 20rpx; width: fit-content;
  transition: all 0.2s;
}
.edit-hint:active { background: #FFE8EE; transform: scale(0.96); }
.edit-hint-text { font-size: 22rpx; font-weight: 700; color: #FF8FAB; }

/* ===== 统计 ===== */
.stats-row {
  display: flex;
  margin: 0 32rpx 32rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #F5F3F7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.stat-item:last-child { border-right: none; }
.stat-icon {
  font-size: 36rpx;
  display: block;
  margin-bottom: 6rpx;
}
.stat-num {
  font-size: 44rpx; font-weight: 900; color: #FF6B8A;
  display: block; margin-bottom: 8rpx;
}
.stat-label { font-size: 24rpx; color: #A8A5B8; }

/* 男生中间占位（空内容，保持布局稳定） */
.stat-placeholder {
  width: 100%;
  height: 100%;
  min-height: 100rpx;
}

/* ===== 菜单 ===== */
.menu-card {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.menu-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid #F8F6FA;
  transition: background 0.2s;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #FFF5F7; }
.menu-icon { font-size: 40rpx; width: 48rpx; text-align: center; }
.menu-name { flex: 1; font-size: 30rpx; font-weight: 600; color: #2D2B41; }
.menu-arrow { font-size: 36rpx; color: #ccc; font-weight: 300; }

.version-box { text-align: center; padding: 60rpx 0; }
.version-text { font-size: 24rpx; color: #ccc; }
