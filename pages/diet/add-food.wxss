page{background:var(--bg,#FFF8F0)}.af-page{height:100vh;display:flex;flex-direction:column;overflow:hidden}

.af-nav{display:flex;align-items:center;justify-content:space-between;padding:calc(env(safe-area-inset-top)+12rpx) 32rpx 16rpx;background:var(--surface,#fff);flex-shrink:0}
.af-back{width:64rpx;height:64rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:var(--bg,#FFF8F0)}
.af-back text{font-size:44rpx;font-weight:300;color:var(--text-primary);line-height:1}
.af-back-h{background:#F0EDE8}
.af-title{font-size:32rpx;font-weight:900;color:var(--text-primary)}
.af-ph{width:64rpx}

.af-search{display:flex;align-items:center;gap:12rpx;padding:12rpx 32rpx;flex-shrink:0}
.af-sbox{flex:1;display:flex;align-items:center;background:var(--surface,#fff);border-radius:48rpx;padding:14rpx 24rpx;box-shadow:var(--shadow-sm)}
.afs-i{font-size:24rpx;margin-right:10rpx;flex-shrink:0}
.afs-in{flex:1;font-size:26rpx;color:var(--text-primary)}
.afs-ph{color:var(--text-muted,#A8A5B8)}
.afs-cl{font-size:24rpx;color:#ccc;padding:8rpx 0 8rpx 12rpx}

/* ★ 多选按钮 */
.multi-btn{padding:12rpx 24rpx;border-radius:28rpx;background:var(--surface,#fff);font-size:22rpx;font-weight:700;color:var(--text-secondary,#6B6880);box-shadow:var(--shadow-sm);flex-shrink:0;transition:all .2s}
.multi-on{background:var(--pink-deep,#FF8FAB);color:#fff;box-shadow:0 4rpx 14rpx rgba(255,143,171,.3)}
.multi-h{opacity:.75}

.af-body{flex:1;display:flex;overflow:hidden}
.af-side{width:150rpx;flex-shrink:0;background:var(--surface,#fff);border-right:2rpx solid #F5F3EF}
.sb-i{display:flex;flex-direction:column;align-items:center;gap:4rpx;padding:22rpx 0;position:relative}
.sb-on{background:var(--bg,#FFF8F0)}
.sb-on::before{content:'';position:absolute;left:0;top:20%;bottom:20%;width:6rpx;border-radius:0 3rpx 3rpx 0;background:linear-gradient(180deg,var(--pink,#FFB4C2),var(--pink-deep,#FF8FAB))}
.sb-icon{font-size:30rpx}.sb-name{font-size:20rpx;font-weight:600;color:var(--text-secondary)}
.sb-on .sb-name{color:var(--pink-deep,#FF8FAB);font-weight:800}

.af-list{flex:1;overflow-y:auto;padding:0 20rpx}
.search-hint{padding:8rpx 8rpx 14rpx;font-size:22rpx;color:var(--text-muted,#A8A5B8)}
.custom-add{display:flex;align-items:center;justify-content:center;gap:10rpx;padding:24rpx;margin-bottom:12rpx;background:#FFF0F3;border:3rpx dashed var(--pink,#FFB4C2);border-radius:var(--radius-lg,24rpx)}
.custom-add-h{background:#FFE8EE}
.ca-i{font-size:28rpx}.ca-t{font-size:24rpx;font-weight:700;color:var(--pink-deep,#FF8FAB)}

/* ★ 食物卡片 + 勾选框 */
.fl-card{display:flex;align-items:center;gap:14rpx;background:var(--surface,#fff);border-radius:var(--radius-md,18rpx);padding:22rpx 18rpx;margin-bottom:12rpx;box-shadow:var(--shadow-sm);transition:all .12s;border:3rpx solid transparent}
.fl-card-h{transform:scale(.97)}
.fl-sel{border-color:var(--pink-deep,#FF8FAB);background:#FFF8FA}

.fl-check{
  width:40rpx;height:40rpx;border-radius:50%;
  border:3rpx solid #D0D0D0;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all .15s;
  font-size:20rpx;color:transparent;
}
.fl-chked{
  background:var(--pink-deep,#FF8FAB);
  border-color:var(--pink-deep,#FF8FAB);
  color:#fff;
}

.fl-icon-box{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;background:var(--bg,#FFF8F0);border-radius:16rpx;flex-shrink:0}
.fl-icon{font-size:34rpx}
.fl-info{flex:1;min-width:0}
.fl-name{font-size:24rpx;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.fl-tags{display:flex;gap:6rpx}
.ft{font-size:16rpx;font-weight:600;padding:2rpx 8rpx;border-radius:6rpx}
.ft-c{background:#FFF3E0;color:#FF9F43}.ft-p{background:#E3F2FD;color:#54A0FF}.ft-f{background:#FFF0F3;color:#FF6B6B}
.fl-cal-box{text-align:right;flex-shrink:0}
.fl-cal-num{font-size:26rpx;font-weight:900;color:var(--coral,#FF6B6B);display:block}
.fl-cal-unit{font-size:16rpx;color:var(--text-muted,#A8A5B8)}
.af-empty{text-align:center;padding:100rpx 0}
.ae-i{font-size:56rpx;display:block;margin-bottom:14rpx}.ae-t{font-size:24rpx;color:var(--text-muted,#A8A5B8)}

/* ★ 多选底部栏 */
.ms-bar{position:fixed;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:space-between;padding:20rpx 32rpx calc(env(safe-area-inset-bottom)+16rpx);background:var(--surface,#fff);box-shadow:0 -2rpx 16rpx rgba(0,0,0,.06);z-index:50}
.msb-count{font-size:28rpx;font-weight:700;color:var(--text-primary)}
.msb-add{padding:18rpx 48rpx;border-radius:40rpx;background:linear-gradient(135deg,var(--pink,#FFB4C2),var(--pink-deep,#FF8FAB));color:#fff;font-size:28rpx;font-weight:800;box-shadow:0 4rpx 16rpx rgba(255,143,171,.3);transition:all .15s}
.msb-dis{opacity:.4;pointer-events:none}
.msb-h{transform:scale(.95)}

/* 底弹层通用 */
.sh-mask{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:100}
.sh-sheet{position:fixed;left:0;right:0;bottom:0;z-index:101;background:var(--surface,#fff);border-radius:32rpx 32rpx 0 0;padding:0 40rpx calc(env(safe-area-inset-bottom)+32rpx);transform:translateY(100%);transition:transform .4s cubic-bezier(.32,.72,0,1);max-height:82vh;overflow-y:auto}
.sh-show{transform:translateY(0)}
.sh-handle{display:flex;justify-content:center;padding:20rpx 0 24rpx}
.sh-bar{width:64rpx;height:8rpx;border-radius:4rpx;background:#E0E0E0}
.sh-head{display:flex;align-items:center;gap:20rpx;margin-bottom:28rpx}
.sh-emoji{font-size:52rpx}.sh-title{flex:1}.sh-name{font-size:32rpx;font-weight:900;color:var(--text-primary);display:block}.sh-sub{font-size:22rpx;color:var(--text-muted,#A8A5B8)}

/* ★ 营养素（图标+数值，无进度条，简洁） */
.sh-macros{display:flex;gap:16rpx;margin-bottom:28rpx}
.shm{flex:1;text-align:center;background:#FAFAF8;border-radius:16rpx;padding:20rpx 0}
.shm-icon{font-size:28rpx;display:block;margin-bottom:6rpx}
.shm-v{font-size:28rpx;font-weight:900;display:block}
.shm-v.c{color:#FF9F43}.shm-v.p{color:#54A0FF}.shm-v.f{color:#FF6B6B}
.shm-l{font-size:20rpx;color:var(--text-muted,#A8A5B8)}

.sh-gram{display:flex;align-items:center;gap:16rpx;margin-bottom:20rpx}
.sh-stepper{flex:1;display:flex;align-items:center;background:#F5F3EF;border-radius:var(--radius-sm,12rpx);overflow:hidden}
.sh-btn{width:84rpx;height:76rpx;display:flex;align-items:center;justify-content:center;font-size:34rpx;color:var(--text-secondary)}
.sh-btn-h{background:#EBEBEB}.sh-btn-p{color:var(--pink-deep,#FF8FAB)}
.sh-input{flex:1;text-align:center;font-size:38rpx;font-weight:900;color:var(--text-primary);height:76rpx;background:transparent}
.sh-unit{font-size:26rpx;color:var(--text-secondary);font-weight:600}
.sh-quick{display:flex;gap:12rpx;margin-bottom:28rpx}
.sq{flex:1;text-align:center;padding:14rpx 0;background:#F5F3EF;border-radius:12rpx;font-size:22rpx;font-weight:700;color:var(--text-secondary);transition:all .15s}
.sq-on{background:#FFF0F3;color:var(--pink-deep,#FF8FAB)}
.sh-cal-dis{text-align:center;margin-bottom:24rpx}
.sh-cal-big{font-size:68rpx;font-weight:900;color:var(--coral,#FF6B6B)}
.sh-cal-suf{font-size:26rpx;color:var(--text-muted,#A8A5B8)}
.sh-confirm{text-align:center;padding:26rpx;border-radius:48rpx;background:linear-gradient(135deg,var(--pink,#FFB4C2),var(--pink-deep,#FF8FAB));color:#fff;font-size:30rpx;font-weight:800;box-shadow:0 8rpx 28rpx rgba(255,143,171,.3);transition:transform .15s;letter-spacing:2rpx}
.sh-confirm-h{transform:scale(.97)}

/* 批量添加 */
.bt-title{font-size:30rpx;font-weight:900;color:var(--text-primary);display:block;margin:4rpx 0 20rpx}
.bt-scroll{max-height:50vh;margin-bottom:20rpx}
.bt-item{display:flex;align-items:center;gap:12rpx;padding:16rpx 0;border-bottom:2rpx solid #F5F3EF}
.bt-emoji{font-size:32rpx;flex-shrink:0}
.bt-name{font-size:24rpx;font-weight:700;color:var(--text-primary);width:120rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex-shrink:0}
.bt-stepper{flex:1;display:flex;align-items:center;background:#F5F3EF;border-radius:10rpx;overflow:hidden}
.bt-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:var(--text-secondary)}
.bt-btn-p{color:var(--pink-deep,#FF8FAB)}
.bt-input{flex:1;text-align:center;font-size:28rpx;font-weight:800;color:var(--text-primary);height:60rpx;background:transparent}
.bt-unit{font-size:22rpx;color:var(--text-muted);flex-shrink:0}
.bt-cal{font-size:24rpx;font-weight:800;color:var(--coral,#FF6B6B);width:80rpx;text-align:right;flex-shrink:0}
.bt-foot{display:flex;align-items:center;justify-content:space-between;padding-top:8rpx}
.bt-total{font-size:26rpx;color:var(--text-secondary);font-weight:600}
.bt-total-n{font-size:32rpx;font-weight:900;color:var(--coral,#FF6B6B)}
.bt-confirm{padding:18rpx 44rpx;border-radius:40rpx;background:linear-gradient(135deg,var(--pink,#FFB4C2),var(--pink-deep,#FF8FAB));color:#fff;font-size:26rpx;font-weight:800;box-shadow:0 4rpx 16rpx rgba(255,143,171,.3)}

/* 自定义表单 */
.cf-title{font-size:30rpx;font-weight:900;color:var(--text-primary);display:block;margin:4rpx 0 24rpx}
.cf-field{margin-bottom:20rpx}
.cf-label{font-size:24rpx;font-weight:700;color:var(--text-secondary);display:block;margin-bottom:8rpx}
.cf-input{width:100%;height:76rpx;background:#F5F3EF;border-radius:var(--radius-sm,12rpx);padding:0 20rpx;font-size:26rpx;font-weight:600;color:var(--text-primary);box-sizing:border-box}
.cf-row{display:flex;gap:12rpx}.cf-third{flex:1}
.cf-save{text-align:center;padding:26rpx;border-radius:48rpx;background:linear-gradient(135deg,var(--mint,#B5EAD7),#8DD5B4);color:#0d6948;font-size:28rpx;font-weight:800;box-shadow:0 4rpx 16rpx rgba(141,213,180,.3);transition:transform .15s;margin-top:12rpx}
.cf-save:active{transform:scale(.97)}
