/* ═══════════════════════════════════════
   ROOT VARIABLES & PAGE
   ═══════════════════════════════════════ */
   page {
    --bg: #FDF9F6;
    --surface: #FFFFFF;
    --pink-deep: #E85A7A;
    --pink: #FFB4C2;
    --coral: #FF6B6B;
    --text-primary: #1A1824;
    --text-secondary: #5E5B6E;
    --text-muted: #A09DB0;
    --radius-xl: 36rpx;
    --radius-md: 20rpx;
    --radius-sm: 14rpx;
    background: var(--bg);
    background-image:
      radial-gradient(ellipse at 10% 90%, rgba(255,180,194,0.1) 0%, transparent 50%),
      radial-gradient(ellipse at 90% 10%, rgba(232,90,122,0.06) 0%, transparent 45%);
  }
  
  .page {
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  /* ═══════════════════════════════════════
     ANIMATIONS
     ═══════════════════════════════════════ */
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(28rpx); }
    to   { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes fadeScale {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }
  
  @keyframes ringGlow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  
  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 8rpx rgba(232,90,122,0.3); }
    50%      { box-shadow: 0 0 20rpx rgba(232,90,122,0.6); }
  }
  
  @keyframes emptyFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-14rpx); }
  }
  
  @keyframes aiShine {
    0%       { transform: translateX(-100%) translateY(-100%) rotate(25deg); }
    70%,100% { transform: translateX(100%) translateY(100%) rotate(25deg); }
  }
  
  @keyframes aiStar {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.3; transform: scale(0.4); }
  }
  
  @keyframes aiGlow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  
  @keyframes aiDotB {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.3; }
    30%           { transform: translateY(-18rpx); opacity: 1; }
  }
  
  @keyframes maskIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  
  @keyframes maskOut {
    from { opacity: 1; }
    to   { opacity: 0; }
  }
  
  @keyframes resIn {
    from { opacity: 0; transform: translateY(20rpx); }
    to   { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes dmIn {
    0%   { opacity: 0; transform: translate(-50%,-50%) scale(0.65) translateY(40rpx); }
    100% { opacity: 1; transform: translate(-50%,-50%) scale(1) translateY(0); }
  }
  
  @keyframes dmStar {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50%      { transform: scale(1.3) rotate(20deg); }
  }
  
  /* ═══════════════════════════════════════
     DATE BAR
     ═══════════════════════════════════════ */
  .date-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: calc(env(safe-area-inset-top) + 16rpx) 36rpx 22rpx;
    background: var(--surface);
    flex-shrink: 0;
    position: relative;
    box-shadow: 0 4rpx 24rpx rgba(26,24,36,0.04);
  }
  
  .date-bar::after {
    content: '';
    position: absolute;
    bottom: -1rpx;
    left: 10%;
    right: 10%;
    height: 3rpx;
    background: linear-gradient(90deg, transparent, var(--pink), var(--pink-deep), var(--pink), transparent);
    opacity: 0.35;
    border-radius: 2rpx;
  }
  
  .da-btn {
    width: 72rpx;
    height: 72rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    transition: all 0.2s ease;
  }
  
  .da-btn text {
    font-size: 42rpx;
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1;
  }
  
  .da-h {
    background: #EDEAE5;
    transform: scale(0.93);
  }
  
  .da-dis {
    opacity: 0.2;
    pointer-events: none;
  }
  
  .da-center {
    display: flex;
    align-items: center;
    gap: 14rpx;
    padding: 14rpx 32rpx;
    border-radius: 44rpx;
    background: var(--bg);
    transition: all 0.2s ease;
  }
  
  .da-date {
    font-size: 36rpx;
    font-weight: 900;
    color: var(--text-primary);
    letter-spacing: -1rpx;
  }
  
  .da-week {
    font-size: 22rpx;
    color: var(--text-muted);
    font-weight: 700;
    letter-spacing: 2rpx;
  }
  
  .da-cal-icon {
    font-size: 28rpx;
    margin-left: 4rpx;
  }
  
  /* ═══════════════════════════════════════
     BACK TO TODAY
     ═══════════════════════════════════════ */
  .back-today {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    padding: 14rpx 0 12rpx;
    background: var(--surface);
    flex-shrink: 0;
  }
  
  .back-today-h { opacity: 0.6; }
  
  .bt-dot {
    width: 16rpx;
    height: 16rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--pink-deep), var(--pink));
    animation: dotPulse 2s ease-in-out infinite;
  }
  
  .bt-text {
    font-size: 24rpx;
    font-weight: 800;
    color: var(--pink-deep);
    letter-spacing: 3rpx;
  }
  
  /* ═══════════════════════════════════════
     BODY / SCROLL
     ═══════════════════════════════════════ */
  .body {
    flex: 1;
    overflow: hidden;
    padding: 0 30rpx;
  }
  
  /* ═══════════════════════════════════════
     PROGRESS CARD
     ═══════════════════════════════════════ */
  .prog-card {
    background: var(--surface);
    border-radius: var(--radius-xl);
    padding: 0 34rpx 30rpx;
    margin: 22rpx 0 26rpx;
    box-shadow:
      0 2rpx 4rpx rgba(26,24,36,0.02),
      0 12rpx 36rpx rgba(26,24,36,0.07);
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: slideUp 0.55s ease 0.05s forwards;
  }
  
  .pc-accent {
    height: 8rpx;
    margin: 0 -34rpx 28rpx;
    background: linear-gradient(90deg, var(--pink), var(--pink-deep), var(--coral), var(--pink-deep), var(--pink));
    background-size: 200% 100%;
    animation: accentShift 4s ease infinite;
  }
  
  @keyframes accentShift {
    0%, 100% { background-position: 0% 0%; }
    50%      { background-position: 100% 0%; }
  }
  
  .pc-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 22rpx;
  }
  
  .pc-label {
    font-size: 20rpx;
    color: var(--text-muted);
    font-weight: 700;
    display: block;
    margin-bottom: 8rpx;
    letter-spacing: 3rpx;
  }
  
  .pc-num-row {
    display: flex;
    align-items: baseline;
    gap: 6rpx;
  }
  
  .pc-num {
    font-size: 60rpx;
    font-weight: 900;
    color: var(--text-primary);
    letter-spacing: -3rpx;
    line-height: 1;
  }
  
  .pc-of {
    font-size: 24rpx;
    color: var(--text-muted);
    font-weight: 600;
  }
  
  .pc-pct-ring {
    width: 96rpx;
    height: 96rpx;
    border-radius: 50%;
    border: 7rpx solid transparent;
    background-image: linear-gradient(#fff, #fff), linear-gradient(135deg, var(--pink), var(--pink-deep));
    background-origin: border-box;
    background-clip: padding-box, border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    opacity: 0;
    animation: fadeScale 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.25s forwards;
  }
  
  .pc-pct-ring::before {
    content: '';
    position: absolute;
    inset: -12rpx;
    border-radius: 50%;
    background: conic-gradient(from 0deg, rgba(232,90,122,0.1), transparent 25%, rgba(232,90,122,0.06) 50%, transparent 75%, rgba(232,90,122,0.1));
    animation: ringGlow 8s linear infinite;
    pointer-events: none;
  }
  
  .pc-pct-val {
    font-size: 28rpx;
    font-weight: 900;
    color: var(--pink-deep);
    position: relative;
    z-index: 1;
  }
  
  .pc-cal-bar {
    margin-bottom: 14rpx;
  }
  
  .pc-cal-track {
    height: 16rpx;
    background: #F0EDF5;
    border-radius: 8rpx;
    overflow: hidden;
  }
  
  .pc-cal-fill {
    height: 100%;
    border-radius: 8rpx;
    background: linear-gradient(90deg, var(--pink), var(--pink-deep));
    transition: width 0.8s cubic-bezier(0.32,0.72,0,1);
    box-shadow: 0 2rpx 12rpx rgba(232,90,122,0.3);
  }
  
  .pc-plan-tag {
    display: inline-block;
    padding: 8rpx 24rpx;
    border-radius: 28rpx;
    background: linear-gradient(135deg, #FFF0F3, #FFE8EE);
    margin-bottom: 18rpx;
  }
  
  .pc-plan-tag text {
    font-size: 20rpx;
    font-weight: 800;
    color: var(--pink-deep);
    letter-spacing: 1rpx;
  }
  
  .pc-macros {
    display: flex;
    flex-direction: column;
    gap: 18rpx;
    margin-top: 22rpx;
  }
  
  .pcm-row {
    display: flex;
    align-items: center;
    gap: 14rpx;
  }
  
  .pcm-icon {
    font-size: 28rpx;
    flex-shrink: 0;
    width: 40rpx;
    text-align: center;
  }
  
  .pcm-name {
    font-size: 22rpx;
    color: var(--text-secondary);
    font-weight: 700;
    width: 68rpx;
    flex-shrink: 0;
    letter-spacing: 1rpx;
  }
  
  .pcm-bar-track {
    flex: 1;
    height: 18rpx;
    background: #F0EDF5;
    border-radius: 9rpx;
    overflow: hidden;
  }
  
  .pcm-bar-fill {
    height: 100%;
    border-radius: 9rpx;
    transition: width 0.65s cubic-bezier(0.32,0.72,0,1);
  }
  
  .pcm-bar-fill.pcm-c {
    background: linear-gradient(90deg, #FFBD4F, #FF9F43);
    box-shadow: 0 2rpx 10rpx rgba(255,159,67,0.35);
  }
  
  .pcm-bar-fill.pcm-p {
    background: linear-gradient(90deg, #74B9FF, #54A0FF);
    box-shadow: 0 2rpx 10rpx rgba(84,160,255,0.35);
  }
  
  .pcm-bar-fill.pcm-f {
    background: linear-gradient(90deg, #FF8A80, #FF6B6B);
    box-shadow: 0 2rpx 10rpx rgba(255,107,107,0.35);
  }
  
  .pcm-val {
    font-size: 22rpx;
    font-weight: 800;
    width: 150rpx;
    text-align: right;
    flex-shrink: 0;
  }
  
  .pcm-cv { color: #FF9F43; }
  .pcm-pv { color: #54A0FF; }
  .pcm-fv { color: #FF6B6B; }
  
  /* ═══════════════════════════════════════
     MESSAGES
     ═══════════════════════════════════════ */
  .msg-bubble {
    padding: 20rpx 30rpx;
    border-radius: 20rpx;
    margin-bottom: 14rpx;
    font-size: 24rpx;
    font-weight: 700;
    opacity: 0;
    animation: slideUp 0.45s ease forwards;
  }
  
  .msg-bubble:nth-child(1) { animation-delay: 0.12s; }
  .msg-bubble:nth-child(2) { animation-delay: 0.22s; }
  .msg-bubble:nth-child(3) { animation-delay: 0.32s; }
  
  .msg-bubble.success {
    background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
    color: #059669;
    border: 2rpx solid rgba(5,150,105,0.08);
  }
  
  .msg-bubble.warn {
    background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
    color: #EA580C;
    border: 2rpx solid rgba(234,88,12,0.08);
  }
  
  .msg-bubble.info {
    background: linear-gradient(135deg, #FFF0F3, #FFE8EE);
    color: var(--pink-deep);
    border: 2rpx solid rgba(232,90,122,0.1);
  }
  
  /* ═══════════════════════════════════════
     BIG DASHED CONTAINER
     ═══════════════════════════════════════ */
  .big-dashed {
    border: 3rpx dashed rgba(255,180,194,0.5);
    border-radius: 32rpx;
    background: rgba(255,180,194,0.02);
    padding: 16rpx 22rpx 26rpx;
    margin-bottom: 20rpx;
    min-height: 220rpx;
    position: relative;
    opacity: 0;
    animation: slideUp 0.55s ease 0.15s forwards;
  }
  
  .big-dashed::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 32rpx;
    background: radial-gradient(ellipse at 50% 0%, rgba(255,180,194,0.05) 0%, transparent 60%);
    pointer-events: none;
  }
  
  /* ═══════════════════════════════════════
     EMPTY STATE
     ═══════════════════════════════════════ */
  .big-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 88rpx 0;
    gap: 18rpx;
  }
  
  .big-empty-icon {
    font-size: 84rpx;
    animation: emptyFloat 3s ease-in-out infinite;
  }
  
  .big-empty-title {
    font-size: 34rpx;
    font-weight: 900;
    color: var(--text-primary);
    letter-spacing: -1rpx;
  }
  
  .big-empty-sub {
    font-size: 24rpx;
    color: var(--text-muted);
    font-weight: 600;
    letter-spacing: 1rpx;
  }
  
  /* ═══════════════════════════════════════
     MEAL BLOCKS
     ═══════════════════════════════════════ */
  .meal-block {
    margin-top: 10rpx;
    opacity: 0;
    animation: slideUp 0.5s ease forwards;
  }
  
  .meal-block:nth-child(1) { animation-delay: 0.2s; }
  .meal-block:nth-child(2) { animation-delay: 0.3s; }
  .meal-block:nth-child(3) { animation-delay: 0.4s; }
  .meal-block:nth-child(4) { animation-delay: 0.5s; }
  .meal-block:nth-child(5) { animation-delay: 0.6s; }
  .meal-block:nth-child(6) { animation-delay: 0.7s; }
  
  .mb-head {
    display: flex;
    align-items: center;
    gap: 22rpx;
    padding: 30rpx 14rpx 22rpx;
  }
  
  .mb-emoji-ring {
    width: 96rpx;
    height: 96rpx;
    border-radius: 30rpx;
    background: linear-gradient(145deg, #FFF0F3, #FFE3EA);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow:
      0 2rpx 6rpx rgba(232,90,122,0.06),
      0 10rpx 20rpx rgba(232,90,122,0.1);
  }
  
  .mb-emoji {
    font-size: 50rpx;
  }
  
  .mb-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
  }
  
  .mb-name {
    font-size: 38rpx;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1.2;
    letter-spacing: -1rpx;
  }
  
  .mb-cal-row {
    display: flex;
    align-items: baseline;
    gap: 6rpx;
  }
  
  .mb-act {
    font-size: 42rpx;
    font-weight: 900;
    color: var(--text-primary);
    transition: color 0.3s ease;
    line-height: 1;
    letter-spacing: -2rpx;
  }
  
  .mb-act-over { color: var(--coral); }
  .mb-act-good { color: #10B981; }
  
  .mb-sep {
    font-size: 28rpx;
    color: var(--text-muted);
    margin: 0 6rpx;
    font-weight: 600;
  }
  
  .mb-tgt {
    font-size: 30rpx;
    font-weight: 700;
    color: var(--text-muted);
    line-height: 1;
  }
  
  .mb-unit {
    font-size: 22rpx;
    color: var(--text-muted);
    margin-left: 8rpx;
    font-weight: 600;
  }
  
  .mb-divider {
    height: 2rpx;
    margin: 14rpx 20rpx;
    background: linear-gradient(90deg, transparent, rgba(255,180,194,0.35), transparent);
  }
  
  /* ═══════════════════════════════════════
     FOOD ITEMS
     ═══════════════════════════════════════ */
  .fd-row {
    display: flex;
    align-items: center;
    gap: 18rpx;
    padding: 22rpx 16rpx;
    border-radius: var(--radius-md);
    transition: all 0.18s ease;
  }
  
  .fd-row-h {
    background: rgba(232,90,122,0.04);
    transform: scale(0.99);
  }
  
  .fd-emoji {
    font-size: 42rpx;
    flex-shrink: 0;
  }
  
  .fd-info {
    flex: 1;
    min-width: 0;
  }
  
  .fd-name {
    font-size: 26rpx;
    font-weight: 800;
    color: var(--text-primary);
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    letter-spacing: -0.5rpx;
  }
  
  .fd-desc {
    font-size: 20rpx;
    color: var(--text-muted);
    display: block;
    margin-top: 6rpx;
    font-weight: 600;
    letter-spacing: 0.5rpx;
  }
  
  .fd-cal-box {
    text-align: right;
    flex-shrink: 0;
    background: linear-gradient(135deg, #FFF5F5, #FFF0F3);
    padding: 10rpx 18rpx;
    border-radius: 18rpx;
    min-width: 100rpx;
  }
  
  .fd-cal {
    font-size: 28rpx;
    font-weight: 900;
    color: var(--coral);
    display: block;
    letter-spacing: -1rpx;
  }
  
  .fd-unit {
    font-size: 16rpx;
    color: var(--text-muted);
    font-weight: 600;
  }
  
  /* ═══════════════════════════════════════
     SNACK PICKER & BOTTOM NAV
     ═══════════════════════════════════════ */
  .snack-mask {
    position: fixed;
    inset: 0;
    z-index: 49;
  }
  
  .bnav-wrap {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--surface);
    box-shadow: 0 -6rpx 32rpx rgba(26,24,36,0.06);
  }
  
  .bnav {
    display: flex;
    align-items: center;
    padding: 18rpx 0 calc(env(safe-area-inset-bottom) + 14rpx);
  }
  
  .bn-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6rpx;
    padding: 12rpx 0;
    transition: all 0.18s ease;
  }
  
  .bn-h {
    transform: scale(0.9);
    opacity: 0.5;
  }
  
  .bn-icon {
    font-size: 42rpx;
  }
  
  .bn-text {
    font-size: 22rpx;
    font-weight: 800;
    color: var(--text-secondary);
    letter-spacing: 1rpx;
  }
  
  .snack-expand {
    position: absolute;
    bottom: 100%;
    right: 0;
    width: 25%;
    background: var(--surface);
    border-radius: 28rpx 28rpx 0 0;
    box-shadow: 0 -8rpx 36rpx rgba(26,24,36,0.08);
    transform: translateY(24rpx);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.25s ease;
    overflow: hidden;
  }
  
  .snack-show {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  
  .se-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6rpx;
    padding: 24rpx 0;
    transition: background 0.15s;
  }
  
  .se-h { background: var(--bg); }
  
  .se-emoji {
    font-size: 36rpx;
  }
  
  .se-text {
    font-size: 22rpx;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: 1rpx;
  }
  
  /* ═══════════════════════════════════════
     CALENDAR
     ═══════════════════════════════════════ */
  .cal-mask {
    position: fixed;
    inset: 0;
    background: rgba(26,24,36,0.45);
    z-index: 100;
    animation: maskIn 0.25s ease;
  }
  
  .cal-pop {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%) scale(0.88);
    width: 660rpx;
    background: var(--surface);
    border-radius: var(--radius-xl);
    padding: 40rpx 36rpx;
    z-index: 101;
    opacity: 0;
    pointer-events: none;
    transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
    box-shadow:
      0 8rpx 20rpx rgba(26,24,36,0.06),
      0 28rpx 68rpx rgba(26,24,36,0.14);
  }
  
  .cal-show {
    opacity: 1;
    transform: translate(-50%,-50%) scale(1);
    pointer-events: auto;
  }
  
  .cal-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 30rpx;
  }
  
  .cal-ar {
    width: 68rpx;
    height: 68rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    transition: all 0.18s ease;
  }
  
  .cal-ar text {
    font-size: 38rpx;
    color: var(--text-primary);
    line-height: 1;
  }
  
  .cal-ar-h {
    background: #E8E4DE;
    transform: scale(0.93);
  }
  
  .cal-month {
    font-size: 34rpx;
