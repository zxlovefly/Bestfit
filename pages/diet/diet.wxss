  .aim {
    display: flex;
    align-items: center;
    gap: 6rpx;
    padding: 14rpx 20rpx;
    border-radius: 26rpx;
    background: #F5F3EF;
    font-size: 20rpx;
    font-weight: 800;
    color: var(--text-secondary);
    transition: all 0.2s;
  }
  
  .aim-e { font-size: 18rpx; }
  .aim-t { font-size: 20rpx; }
  
  .aim-on {
    background: linear-gradient(135deg, var(--pink), var(--pink-deep));
    color: #fff;
    box-shadow: 0 4rpx 16rpx rgba(232,90,122,0.35);
  }
  
  .ai-foot {
    display: flex;
    gap: 14rpx;
    margin-top: 10rpx;
  }
  
  .ai-foot-retry {
    flex: 1;
    text-align: center;
    padding: 20rpx;
    border-radius: 36rpx;
    background: #F5F3EF;
    font-size: 22rpx;
    font-weight: 800;
    color: var(--text-secondary);
    transition: all 0.15s;
  }
  
  .ai-foot-ok {
    flex: 2;
    text-align: center;
    padding: 20rpx;
    border-radius: 36rpx;
    background: linear-gradient(135deg, var(--pink), var(--pink-deep));
    color: #fff;
    font-size: 24rpx;
    font-weight: 800;
    box-shadow: 0 8rpx 28rpx rgba(232,90,122,0.38);
    transition: all 0.15s;
    letter-spacing: 2rpx;
  }
  
  .ai-foot-ok-h { transform: scale(0.97); }
  
  .ai-mask {
    position: fixed;
    inset: 0;
    background: rgba(26,24,36,0.2);
    z-index: 58;
    animation: maskIn 0.3s ease;
  }
  
  .ai-mask-out {
    animation: maskOut 0.3s ease forwards;
  }
  
  /* ═══════════════════════════════════════
     DELETE CONFIRM MODAL
     ═══════════════════════════════════════ */
  .dm-mask {
    position: fixed;
    inset: 0;
    background: rgba(26,24,36,0.45);
    z-index: 200;
    animation: maskIn 0.25s ease;
  }
  
  .dm-box {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    width: 580rpx;
    background: #fff;
    border-radius: 52rpx;
    padding: 48rpx 44rpx 40rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow:
      0 8rpx 24rpx rgba(26,24,36,0.08),
      0 28rpx 72rpx rgba(26,24,36,0.16);
    animation: dmIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
    z-index: 201;
  }
  
  .dm-deco {
    position: absolute;
    top: -20rpx;
    font-size: 26rpx;
    color: #f59e0b;
    animation: dmStar 2s ease-in-out infinite;
  }
  
  .dm-icon-ring {
    width: 116rpx;
    height: 116rpx;
    border-radius: 50%;
    background: linear-gradient(145deg, #FFF0F3, #FFE3EA);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 30rpx;
    position: relative;
    box-shadow: 0 6rpx 20rpx rgba(232,90,122,0.12);
  }
  
  .dm-emoji { font-size: 52rpx; }
  
  .dm-qm {
    position: absolute;
    bottom: -6rpx;
    right: -6rpx;
    width: 44rpx;
    height: 44rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--pink), var(--pink-deep));
    color: #fff;
    font-size: 24rpx;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4rpx 16rpx rgba(232,90,122,0.35);
  }
  
  .dm-title {
    font-size: 36rpx;
    font-weight: 900;
    color: var(--text-primary);
    margin-bottom: 12rpx;
    letter-spacing: -1rpx;
  }
  
  .dm-desc {
    font-size: 24rpx;
    color: var(--text-muted);
    margin-bottom: 44rpx;
    font-weight: 600;
  }
  
  .dm-btns {
    display: flex;
    gap: 18rpx;
    width: 100%;
  }
  
  .dm-btn {
    flex: 1;
    height: 90rpx;
    border-radius: 48rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  
  .dm-btn-h { transform: scale(0.95); }
  
  .dm-cancel {
    background: #F5F3EF;
  }
  
  .dm-ok {
    background: linear-gradient(135deg, var(--pink), var(--pink-deep));
    box-shadow: 0 8rpx 32rpx rgba(232,90,122,0.38);
  }
  
  .dm-btn-t {
    font-size: 28rpx;
    font-weight: 800;
    color: var(--text-secondary);
  }
  
  .dm-btn-tw { color: #fff; }
  