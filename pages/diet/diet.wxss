  /* ═══════════════════════════════════════
     AI MORPH / PANEL
     ═══════════════════════════════════════ */
  .ai-morph {
    position: fixed;
    right: 28rpx;
    bottom: 195rpx;
    z-index: 60;
    overflow: hidden;
    width: 92rpx;
    height: 92rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #FF8FAB 0%, #FF6B9D 50%, #E8538E 100%);
    box-shadow:
      0 4rpx 12rpx rgba(232,83,142,0.3),
      0 14rpx 36rpx rgba(232,83,142,0.28);
    transition: width 0.4s ease-out, height 0.4s ease-out, border-radius 0.4s ease-out, background 0.4s ease-out, box-shadow 0.4s ease-out;
  }
  
  .ai-morph.ai-expanded {
    width: 702rpx;
    height: 70vh;
    border-radius: 36rpx;
    background: #fff;
    box-shadow:
      0 8rpx 24rpx rgba(26,24,36,0.08),
      0 36rpx 72rpx rgba(26,24,36,0.14);
    transition: width 0.5s cubic-bezier(0.34,1.56,0.64,1), height 0.5s cubic-bezier(0.34,1.56,0.64,1), border-radius 0.5s cubic-bezier(0.34,1.56,0.64,1), background 0.5s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }
  
  .ai-morph::before {
    content: '';
    position: absolute;
    top: -80%;
    left: -80%;
    width: 260%;
    height: 260%;
    background: linear-gradient(115deg, transparent 25%, rgba(255,255,255,0) 40%, rgba(255,255,255,0.25) 47%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0.25) 53%, rgba(255,255,255,0) 60%, transparent 75%);
    animation: aiShine 3.5s infinite;
    pointer-events: none;
    z-index: 1;
  }
  
  .ai-morph::after {
    content: '✦';
    position: absolute;
    top: 8rpx;
    right: 14rpx;
    font-size: 14rpx;
    color: rgba(255,255,255,0.85);
    animation: aiStar 2s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  
  .ai-morph.ai-expanded::before,
  .ai-morph.ai-expanded::after { display: none; }
  
  .ai-bub {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
    opacity: 1;
    transition: opacity 0.25s 0.1s;
  }
  
  .ai-morph.ai-expanded .ai-bub {
    opacity: 0;
    transition: opacity 0.12s;
    pointer-events: none;
  }
  
  .ai-bub-glow {
    position: absolute;
    inset: -6rpx;
    border-radius: 50%;
    background: conic-gradient(from 0deg, rgba(255,143,171,0.3), transparent, rgba(255,143,171,0.15), transparent, rgba(255,143,171,0.3));
    animation: aiGlow 4s linear infinite;
    filter: blur(6rpx);
    pointer-events: none;
  }
  
  .ai-bub-ico {
    font-size: 24rpx;
    position: relative;
    z-index: 1;
    margin-bottom: -2rpx;
  }
  
  .ai-bub-lbl {
    font-size: 22rpx;
    font-weight: 900;
    color: #fff;
    letter-spacing: 3rpx;
    position: relative;
    z-index: 1;
    text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.2);
  }
  
  .ai-pan {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transition: opacity 0.12s;
    pointer-events: none;
  }
  
