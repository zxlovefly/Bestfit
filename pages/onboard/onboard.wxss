.onboard-wrap {
  width: 100%;
  height: 100vh;
  background: linear-gradient(160deg, #fff0f3, #fff9f0);
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 花瓣飘落容器 铺满全屏 */
.petal-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}
/* 花瓣样式 */
.petal {
  position: absolute;
  top: -10%;
  left: var(--left);
  width: var(--size);
  height: var(--size);
  background: #ffc8d0;
  border-radius: 0 50% 50% 50%;
  opacity: 0.7;
  transform: rotate(45deg);
  animation: petalFall var(--duration) linear var(--delay) infinite;
}
/* 飘落动画：下落+左右摇摆+旋转 */
@keyframes petalFall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 0.8;
  }
  90% {
    opacity: 0.7;
  }
  100% {
    transform: translateY(110vh) translateX(40rpx) rotate(720deg);
    opacity: 0;
  }
}

/* 中间白色大圆 */
.circle-box {
  width: 480rpx;
  height: 480rpx;
  background: rgba(255,255,255,0.65);
  border-radius: 50%;
  position: relative;
  margin-bottom: 60rpx;
  overflow: hidden;
  z-index: 2;
}

/* 奔跑人物 */
.runner {
  font-size: 80rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  width: 80rpx;
  height: 80rpx;
  margin-top: -40rpx;
  margin-left: -40rpx;
}
.man {
  animation: runMan 8s linear infinite;
}
.woman {
  animation: runWoman 8s linear infinite;
  animation-delay: 4s;
}
@keyframes runMan {
  0% { transform: rotate(0deg) translateX(160rpx) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(160rpx) rotate(-360deg); }
}
@keyframes runWoman {
  0% { transform: rotate(0deg) translateX(160rpx) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(160rpx) rotate(-360deg); }
}

/* 星星 */
.star {
  position: absolute;
  font-size: 40rpx;
  opacity: 0.7;
  z-index: 2;
}
.star1 { top: 35%; left: 12%; }
.star2 { top: 42%; right: 15%; }

.text-box {
  text-align: center;
  margin-bottom: 80rpx;
  z-index: 2;
}
.title {
  font-size: 48rpx;
  font-weight: 900;
  color: #2D2B41;
  display: block;
  margin-bottom: 20rpx;
}
.desc {
  font-size: 28rpx;
  color: #A8A5B8;
}

.start-btn {
  width: 320rpx;
  height: 90rpx;
  background: linear-gradient(90deg, #ffb4c2, #ff8fab);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  z-index: 2;
}