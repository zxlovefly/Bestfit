.page {
  background: #f5ece3;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ---- 顶部 ---- */
.head {
  text-align: center;
  padding: 36rpx 40rpx 12rpx;
}
.title {
  font-size: 38rpx;
  font-weight: 800;
  color: #3e2f23;
  letter-spacing: 6rpx;
}

/* ---- 日历卡片 ---- */
.calendar {
  background: #fff;
  margin: 20rpx 28rpx 0;
  border-radius: 28rpx;
  padding: 28rpx 20rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(80, 50, 20, 0.06);
}
.month-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 12rpx;
}
.month-btn {
  font-size: 28rpx;
  color: #cc9966;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}
.month-btn:active {
  background: rgba(204, 153, 102, 0.12);
}
.month-now {
  font-size: 34rpx;
  font-weight: 700;
  color: #3e2f23;
}
.week-row {
  display: flex;
  margin-bottom: 10rpx;
}
.week-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #b09a85;
  padding: 8rpx 0;
}
.day-grid {
  display: flex;
  flex-wrap: wrap;
}
.day-cell {
  width: 14.28%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border: 3rpx solid transparent;
  border-radius: 50%;
}
.day-num {
  font-size: 30rpx;
  color: #3e2f23;
  line-height: 1;
}
.day-cell.today {
  background: #cc9966;
  border-color: #cc9966;
}
.day-cell.today .day-num {
  color: #fff;
  font-weight: bold;
}
.day-cell.sel {
  border-color: #cc9966;
  background: #fff7ed;
}
.day-cell.sel .day-num {
  color: #b3722b;
  font-weight: bold;
}
.day-cell.today.sel {
  background: #cc9966;
  border-color: #a0723d;
}
.day-cell.today.sel .day-num {
  color: #fff;
}
.day-cell:not(.empty):active {
  background: rgba(204, 153, 102, 0.15);
}
.dot {
  width: 10rpx;
  height: 10rpx;
  background: #cc9966;
  border-radius: 50%;
  margin-top: 6rpx;
}
.day-cell.today .dot {
  background: #fff;
}
.day-cell.sel .dot {
  background: #b3722b;
}

/* ---- 记录区域 ---- */
.record-section {
  background: #fff;
  margin: 20rpx 28rpx 0;
  border-radius: 28rpx;
  padding: 24rpx 28rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(80, 50, 20, 0.06);
}
.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  margin-bottom: 8rpx;
  border-bottom: 1rpx solid #f0e8df;
}
.record-date {
  font-size: 30rpx;
  font-weight: 700;
  color: #3e2f23;
}
.record-count {
  font-size: 22rpx;
  color: #b09a85;
  background: #f8f2eb;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.record-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f4ef;
}
.record-card:last-child {
  border-bottom: none;
}
.record-card:active {
  background: #fdf7f0;
}
.rc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.rc-time-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.rc-color-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.rc-time {
  font-size: 30rpx;
  font-weight: 700;
  color: #3e2f23;
}
.rc-dur {
  font-size: 22rpx;
  color: #b09a85;
  background: #f5efe8;
  padding: 2rpx 14rpx;
  border-radius: 12rpx;
}
.rc-arrow {
  font-size: 36rpx;
  color: #ccc5b8;
  font-weight: 300;
}
.rc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}
.rc-tag {
  font-size: 22rpx;
  color: #8d7b6b;
  background: #f5efe8;
  padding: 4rpx 16rpx;
  border-radius: 14rpx;
}
.rc-tag.main {
  color: #b3722b;
  background: #fff3e0;
  font-weight: 600;
}
.rc-note {
  font-size: 24rpx;
  color: #b09a85;
  display: block;
  margin-top: 10rpx;
}
.no-record {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0 24rpx;
}
.no-icon {
  font-size: 52rpx;
  margin-bottom: 10rpx;
}
.no-text {
  font-size: 26rpx;
  color: #c4b5a5;
}

/* ---- 记录按钮 ---- */
.log-btn {
  width: 80%;
  margin: 32rpx auto 0;
  background: linear-gradient(135deg, #cc9966, #b8824a);
  color: #fff;
  border: none;
  border-radius: 56rpx;
  font-size: 32rpx;
  font-weight: 800;
  padding: 24rpx 0;
  letter-spacing: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 8rpx 32rpx rgba(184, 130, 74, 0.35);
}
.btn-plus {
  font-size: 38rpx;
  line-height: 1;
}
.log-btn:active {
  transform: scale(0.97);
}

/* ---- 广告 ---- */
.ad-card {
  width: 88%;
  margin: 32rpx auto 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(80, 50, 20, 0.05);
}
.ad-icon {
  font-size: 64rpx;
  margin-right: 22rpx;
}
.ad-body {
  flex: 1;
}
.ad-t1 {
  font-size: 30rpx;
  font-weight: 700;
  color: #3e2f23;
  display: block;
  margin-bottom: 4rpx;
}
.ad-t2 {
  font-size: 24rpx;
  color: #b09a85;
  display: block;
}
.ad-close {
  position: absolute;
  top: 18rpx;
  right: 22rpx;
  font-size: 34rpx;
  color: #ccc;
  padding: 4rpx 10rpx;
}

/* ============================== */
/* ========== 详情弹窗 ========== */
/* ============================== */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.25s ease;
}
.detail-popup {
  width: 84%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
  animation: cardIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.detail-bar {
  height: 8rpx;
  width: 100%;
}
.detail-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  font-size: 40rpx;
  color: #ccc;
  z-index: 10;
  padding: 4rpx 12rpx;
}
.detail-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 32rpx 36rpx 20rpx;
}
.detail-color-big {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}
.detail-title-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.detail-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #3e2f23;
}
.detail-sub {
  font-size: 26rpx;
  color: #b09a85;
}
.detail-body {
  padding: 0 36rpx;
}
.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f0eb;
}
.detail-row:last-child {
  border-bottom: none;
}
.detail-label {
  font-size: 28rpx;
  color: #8d7b6b;
  flex-shrink: 0;
  min-width: 140rpx;
}
.detail-val {
  font-size: 28rpx;
  color: #3e2f23;
  font-weight: 600;
  text-align: right;
  flex: 1;
}
.detail-val.note-val {
  font-weight: 400;
  color: #666;
}
.detail-val-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: flex-end;
  flex: 1;
}
.detail-mini-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.detail-num-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #cc9966;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.detail-val-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}
.detail-desc {
  font-size: 22rpx;
  color: #b09a85;
  font-weight: 400;
}
.detail-actions {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 36rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}
.detail-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 700;
}
.detail-btn-del {
  background: #fff5f5;
  color: #e74c3c;
  border: 2rpx solid #fdd;
}
.detail-btn-del:active {
  background: #ffecec;
}
.detail-btn-close {
  background: linear-gradient(135deg, #cc9966, #b8824a);
  color: #fff;
}
.detail-btn-close:active {
  opacity: 0.85;
}

/* ============================== */
/* ===== 自定义确认弹窗（可爱） ===== */
/* ============================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.2s ease;
}
@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-card {
  width: 72%;
  background: #fffcf7;
  border-radius: 40rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: cardBounce 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 20rpx 60rpx rgba(80, 50, 20, 0.15);
}
@keyframes cardBounce {
  0% { opacity: 0; transform: scale(0.6) translateY(40rpx); }
  60% { transform: scale(1.08) translateY(-6rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: emojiShake 0.6s ease 0.3s;
}
@keyframes emojiShake {
  0%, 100% { transform: rotate(0deg); }
  20% { transform: rotate(-12deg); }
  40% { transform: rotate(12deg); }
  60% { transform: rotate(-8deg); }
  80% { transform: rotate(8deg); }
}

.modal-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #3e2f23;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}
.modal-content {
  font-size: 26rpx;
  color: #a09080;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 36rpx;
  white-space: pre-wrap;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  width: 100%;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 700;
  transition: all 0.2s;
}
.modal-btn.cancel {
  background: #f5efe8;
  color: #a09080;
}
.modal-btn.cancel:active {
  background: #ebe3d8;
}
.modal-btn.confirm {
  background: linear-gradient(135deg, #ff8a80, #e57373);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(229, 115, 115, 0.3);
}
.modal-btn.confirm:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* ============================== */
/* ========== 自定义 Toast ========= */
/* ============================== */
.toast-wrap {
  position: fixed;
  top: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1200;
  opacity: 0;
  pointer-events: none;
}
.toast-wrap.show {
  opacity: 1;
  animation: toastSlideIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
.toast-wrap.hiding {
  animation: toastSlideOut 0.3s ease forwards;
}
@keyframes toastSlideIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(-40rpx) scale(0.85);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
}
@keyframes toastSlideOut {
  from {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  to {
    opacity: 0;
    transform: translateX(-50%) translateY(-30rpx) scale(0.9);
  }
}

.toast-box {
  background: rgba(62, 47, 35, 0.88);
  backdrop-filter: blur(20rpx);
  border-radius: 48rpx;
  padding: 18rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.18);
  white-space: nowrap;
}
.toast-emoji {
  font-size: 32rpx;
}
.toast-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}
