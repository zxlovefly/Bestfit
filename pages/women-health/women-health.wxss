.wh-page{min-height:100vh;background:#FFF5F7;background-image:radial-gradient(circle at 15% 85%,rgba(255,107,138,.04) 0%,transparent 50%),radial-gradient(circle at 85% 15%,rgba(179,157,219,.04) 0%,transparent 50%)}
.card{margin:24rpx 32rpx;background:#fff;border-radius:32rpx;padding:36rpx;box-shadow:0 6rpx 32rpx rgba(255,107,138,.06);position:relative;overflow:hidden}
.card-ttl{font-size:32rpx;font-weight:800;color:#2D2B41;display:block}

/* ===== 头部 ===== */
.wh-header{background:linear-gradient(180deg,#FFF0F3 0%,#FFE8EE 60%,#FFF5F7 100%);padding:0 40rpx 48rpx;border-radius:0 0 52rpx 52rpx;position:relative;overflow:hidden}
.wh-header::before{content:'';position:absolute;top:-100rpx;right:-80rpx;width:360rpx;height:360rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,107,138,.08) 0%,transparent 70%);pointer-events:none}
.wh-header::after{content:'';position:absolute;bottom:-60rpx;left:-40rpx;width:240rpx;height:240rpx;border-radius:50%;background:radial-gradient(circle,rgba(179,157,219,.06) 0%,transparent 70%);pointer-events:none}

.float-decor{position:absolute;pointer-events:none;z-index:1}
.fd-1{top:60rpx;left:60rpx;font-size:28rpx;animation:fdFloat 7s ease-in-out infinite;opacity:.35}
.fd-2{top:140rpx;right:50rpx;font-size:22rpx;animation:fdFloat 9s ease-in-out infinite 1.5s;opacity:.3}
.fd-3{top:260rpx;left:180rpx;font-size:20rpx;animation:fdFloat 6s ease-in-out infinite 3s;opacity:.25}
.fd-4{bottom:40rpx;right:100rpx;font-size:26rpx;animation:fdFloat 8s ease-in-out infinite 2s;opacity:.3}
@keyframes fdFloat{0%,100%{transform:translateY(0) rotate(0deg)}25%{transform:translateY(-18rpx) rotate(6deg)}50%{transform:translateY(-6rpx) rotate(-4deg)}75%{transform:translateY(-22rpx) rotate(4deg)}}

.hdr-bar{display:flex;justify-content:space-between;align-items:center;padding:40rpx 0 20rpx;position:relative;z-index:2}
.back{font-size:52rpx;color:#2D2B41;font-weight:300;width:60rpx}
.bell{font-size:40rpx;width:60rpx;text-align:right}

/* ===== 进度环 ===== */
.ring-wrap{display:flex;justify-content:center;margin:24rpx 0;position:relative;z-index:2}
.ring{width:280rpx;height:280rpx;border-radius:50%;border:16rpx solid;display:flex;align-items:center;justify-content:center;transition:all .6s;box-shadow:0 8rpx 40rpx rgba(0,0,0,.04)}
.ring.period-ring{animation:periodGlow 2.5s ease-in-out infinite}
@keyframes periodGlow{0%,100%{box-shadow:0 8rpx 40rpx rgba(255,107,138,.12)}50%{box-shadow:0 8rpx 60rpx rgba(255,107,138,.28)}}

/* 经期结束环 */
.ring.ended-ring{border-color:#3BA55D;background:conic-gradient(#E8F5EE 0%,#3BA55D 100%);border-width:16rpx;box-shadow:0 8rpx 40rpx rgba(59,165,93,.12)}
.ring-in.ended-ring-in{background:linear-gradient(135deg,#ffffff,#FAFFF9)}
.ended-num{color:#3BA55D !important}
.ended-lbl{color:#6EAD84 !important}

.ring-in{width:220rpx;height:220rpx;border-radius:50%;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 8rpx 32rpx rgba(0,0,0,.05)}
.ring-num{font-size:88rpx;font-weight:900;line-height:1}
.ring-lbl{font-size:22rpx;color:#9E9BB0;margin-top:4rpx}

.badge{display:inline-flex;align-items:center;gap:12rpx;padding:14rpx 36rpx;border-radius:40rpx;margin:16rpx auto 24rpx;font-size:28rpx;font-weight:800;position:relative;z-index:2}

.cd-bar{display:flex;align-items:center;justify-content:center;gap:40rpx;background:rgba(255,255,255,.75);border-radius:28rpx;padding:28rpx 0;backdrop-filter:blur(10px);position:relative;z-index:2}
.cd{text-align:center;flex:1}
.cd-n{font-size:48rpx;font-weight:900;color:#2D2B41;display:block}
.cd-l{font-size:22rpx;color:#9E9BB0}
.cd-s{width:2rpx;height:48rpx;background:rgba(0,0,0,.08)}

.period-hint{text-align:center;font-size:24rpx;color:#FF8FAB;margin-top:16rpx;position:relative;z-index:2;font-weight:600;padding:0 16rpx;line-height:1.6}
.period-hint.warn{color:#E85D5D;animation:hintPulse 2s ease-in-out infinite}
@keyframes hintPulse{0%,100%{opacity:1}50%{opacity:.65}}

/* 经期结束提示 */
.ended-tip{text-align:center;font-size:23rpx;color:#8EBA9F;margin-top:16rpx;position:relative;z-index:2;font-weight:600;padding:0 20rpx;line-height:1.6;background:rgba(59,165,93,.06);border-radius:20rpx;padding:14rpx 24rpx;margin-left:16rpx;margin-right:16rpx}

.empty-hdr{display:flex;flex-direction:column;align-items:center;padding:40rpx 0;position:relative;z-index:2}
.eh-emoji{font-size:88rpx;margin-bottom:16rpx;animation:bounceEmoji 2s ease-in-out infinite}
@keyframes bounceEmoji{0%,100%{transform:translateY(0)}50%{transform:translateY(-12rpx)}}
.eh-title{font-size:36rpx;font-weight:800;color:#2D2B41;margin-bottom:12rpx}
.eh-hint{font-size:26rpx;color:#B0A8C0}

/* ===== 日历 ===== */
.cal-card{padding:32rpx}
.cal-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx}
.cal-top .card-ttl{margin-bottom:0}
.cal-tip{font-size:24rpx;color:#FF6B8A;font-weight:600;animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.cal-nav{display:flex;align-items:center;justify-content:center;gap:40rpx;margin-bottom:28rpx}
.nav-a{font-size:44rpx;color:#aaa;font-weight:300;padding:0 16rpx;transition:color .2s}
.nav-a:active{color:#FF6B8A}
.nav-m{font-size:30rpx;font-weight:800;color:#2D2B41}
.wk{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:16rpx}
.wk text{text-align:center;font-size:22rpx;color:#aaa;font-weight:700}
.dg{display:grid;grid-template-columns:repeat(7,1fr);gap:6rpx}
.d{aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:700;border-radius:50%;color:#555;position:relative;transition:all .2s}
.d.empty{visibility:hidden}
.d.period-recorded{background:#E8356B;color:#fff;font-weight:800}
.d.period-active{background:#FF6B8A;color:#fff;font-weight:800}
.d.period-predicted{background:#FFD6E4;color:#D44A72;font-weight:700}
.d.ovulation{background:#FFB347;color:#fff;font-weight:800}
.d.follicular{background:#C8F7DC;color:#2D8A52;font-weight:700}
.d.luteal{background:#E8D5F5;color:#7B5AA6;font-weight:700}
.d.today::after{content:'';position:absolute;bottom:4rpx;left:50%;transform:translateX(-50%);width:8rpx;height:8rpx;border-radius:50%}
.d.normal.today::after{background:#FF6B8A}
.d.period-recorded.today::after,.d.period-active.today::after{background:#fff}
.d.period-predicted.today::after{background:#E8356B}
.d.ovulation.today::after{background:#fff}
.d.follicular.today::after{background:#2D8A52}
.d.luteal.today::after{background:#7B5AA6}
.d.selected{box-shadow:0 0 0 4rpx #FF6B8A,0 4rpx 18rpx rgba(255,107,138,.35);transform:scale(1.18);z-index:2}
.leg{display:flex;justify-content:center;flex-wrap:wrap;gap:20rpx;margin-top:28rpx}
.lg{display:flex;align-items:center;gap:8rpx}
.ld{width:18rpx;height:18rpx;border-radius:6rpx}
.ld.lr{background:#E8356B}.ld.la{background:#FF6B8A}.ld.lp{background:#FFD6E4}.ld.lo{background:#FFB347}.ld.lf{background:#C8F7DC}.ld.ll{background:#E8D5F5}
.lg text{font-size:20rpx;color:#999}
.sel-bar{display:flex;align-items:center;justify-content:space-between;margin-top:24rpx;padding-top:24rpx;border-top:1rpx solid #F5F3F7}
.sel-left{display:flex;align-items:center;gap:12rpx}
.sel-dot{width:16rpx;height:16rpx;border-radius:50%}
.sel-date{font-size:28rpx;font-weight:800;color:#2D2B41}
.sel-phase{font-size:24rpx;font-weight:700}
.sel-btn{font-size:26rpx;font-weight:700;color:#FF6B8A;background:#FFF0F3;padding:12rpx 28rpx;border-radius:30rpx;transition:all .2s}
.sel-btn:active{transform:scale(.93);background:#FFE0EA}

/* ===== 经期日养 ===== */
.daily-card{border-left:8rpx solid #FF6B8A;background:linear-gradient(135deg,#fff 0%,#FFFBFC 100%)}
.daily-card::before{content:'';position:absolute;top:-60rpx;right:-60rpx;width:240rpx;height:240rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,107,138,.05) 0%,transparent 70%);pointer-events:none}
.daily-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28rpx;position:relative;z-index:1}
.daily-day-badge{background:linear-gradient(135deg,#FF6B8A,#FF8FAB);color:#fff;font-size:24rpx;font-weight:800;padding:10rpx 28rpx;border-radius:24rpx;box-shadow:0 4rpx 16rpx rgba(255,107,138,.25)}
.daily-section{display:flex;gap:24rpx;padding:28rpx;background:#FFF8F9;border-radius:28rpx;position:relative;z-index:1}
.daily-icon{font-size:56rpx;flex-shrink:0;width:72rpx;display:flex;align-items:center;justify-content:center}
.daily-info{flex:1;display:flex;flex-direction:column;gap:8rpx}
.daily-title{font-size:30rpx;font-weight:800;color:#2D2B41;display:block}
.daily-desc{font-size:26rpx;color:#666;line-height:1.7;display:block}
.daily-meta-wrap{margin-top:4rpx}
.daily-meta{font-size:22rpx;color:#FF6B8A;background:#FFF0F3;padding:8rpx 18rpx;border-radius:16rpx;display:inline-block;line-height:1.4}
.daily-divider{display:flex;align-items:center;gap:20rpx;margin:24rpx 0;position:relative;z-index:1}
.divider-line{flex:1;height:1rpx;background:linear-gradient(90deg,transparent,#FFE0EA,transparent)}
.divider-text{font-size:22rpx;color:#FFB4C8;font-weight:700;white-space:nowrap}

/* ===== 心情/症状 ===== */
.sec-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:24rpx}
.sec-head .card-ttl{margin-bottom:0}
.sec-add{font-size:26rpx;font-weight:700;color:#FF6B8A;background:#FFF0F3;padding:10rpx 24rpx;border-radius:24rpx;transition:all .2s}
.sec-add:active{transform:scale(.93);background:#FFE0EA}
.log-list{margin-top:8rpx}
.log-item{display:flex;align-items:center;gap:16rpx;padding:20rpx 0;border-bottom:1rpx solid #F8F5FA}
.log-item:last-child{border-bottom:none}
.log-emoji{font-size:40rpx}
.log-sym-icon{font-size:36rpx;width:48rpx;text-align:center}
.log-body{flex:1}
.log-name{font-size:28rpx;font-weight:700;color:#2D2B41;display:block}
.log-time{font-size:22rpx;color:#bbb;margin-top:4rpx}
.log-del{font-size:36rpx;color:#FFB4C8;width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:all .2s}
.log-del:active{background:#FFE0EA;color:#E8356B}
.empty-sec{display:flex;align-items:center;gap:16rpx;padding:24rpx 0}
.empty-emoji-sm{font-size:40rpx}
.empty-text-sm{font-size:26rpx;color:#ccc}

/* ===== 摘要/建议/历史 ===== */
.si{font-size:48rpx;margin-bottom:12rpx;display:block}
.sw{display:flex;flex-direction:column;gap:8rpx}
.sp{font-size:30rpx;font-weight:800}
.st{font-size:28rpx;color:#555;line-height:1.7}
.tips-card{padding-bottom:20rpx}
.tabs{display:flex;gap:16rpx;margin-bottom:28rpx}
.tab{flex:1;text-align:center;padding:18rpx 0;border-radius:24rpx;background:#F8F6FA;font-size:26rpx;font-weight:700;color:#9E9BB0;transition:all .3s}
.tab.act{font-weight:800}
.tl{padding:0 8rpx}
.ti{display:flex;align-items:flex-start;gap:16rpx;margin-bottom:20rpx}
.td{width:14rpx;height:14rpx;border-radius:50%;margin-top:12rpx;flex-shrink:0}
.tt{font-size:27rpx;color:#444;line-height:1.6}
.hi{display:flex;align-items:center;gap:20rpx;padding:24rpx 0;border-bottom:1rpx solid #F5F3F7}
.hi:last-child{border-bottom:none}
.hd{width:16rpx;height:16rpx;border-radius:50%;flex-shrink:0}
.hn{flex:1}
.hm{font-size:28rpx;font-weight:700;color:#2D2B41;display:block;margin-bottom:6rpx}
.hx{font-size:24rpx;color:#aaa}
.ht{font-size:22rpx;font-weight:700;padding:8rpx 20rpx;border-radius:20rpx;flex-shrink:0}
.emp{text-align:center;padding:40rpx 0}
.emp-e{font-size:64rpx;display:block;margin-bottom:16rpx}
.emp-t{font-size:26rpx;color:#bbb}

/* ===== 弹窗 ===== */
.mm{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:80;opacity:0;pointer-events:none;transition:opacity .3s}
.mm.show{opacity:1;pointer-events:auto}
.popup{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:40rpx 40rpx 0 0;padding:16rpx 40rpx 80rpx;z-index:81;transform:translateY(100%);transition:transform .38s cubic-bezier(.32,.72,0,1);max-height:75vh;overflow-y:auto}
.popup.show{transform:translateY(0)}
.p-h{width:64rpx;height:8rpx;border-radius:4rpx;background:#E0DDE5;margin:0 auto 28rpx}
.p-title{font-size:36rpx;font-weight:900;color:#2D2B41;display:block;margin-bottom:8rpx}
.p-date{font-size:26rpx;color:#aaa;display:block;margin-bottom:28rpx}
.m-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16rpx;margin-bottom:32rpx}
.m-item{display:flex;flex-direction:column;align-items:center;padding:24rpx 8rpx;border-radius:28rpx;background:#FAFAFA;border:3rpx solid transparent;transition:all .25s}
.m-item.sel{background:#FFF0F3;border-color:#FF6B8A;transform:scale(1.08);box-shadow:0 6rpx 24rpx rgba(255,107,138,.2)}
.m-item:active{transform:scale(.94)}
.m-emoji{font-size:48rpx;margin-bottom:8rpx}
.m-text{font-size:22rpx;font-weight:700;color:#8E8BA0}
.s-grid{display:flex;flex-wrap:wrap;gap:16rpx;margin-bottom:32rpx}
.s-item{padding:18rpx 28rpx;border-radius:40rpx;background:#FAFAFA;border:3rpx solid #F0EDF5;font-size:26rpx;font-weight:700;color:#8E8BA0;transition:all .25s}
.s-item.sel{background:#FFF0F3;border-color:#FF6B8A;color:#FF6B8A;transform:scale(1.05)}
.s-item:active{transform:scale(.94)}
.p-btn{width:100%;border-radius:60rpx;padding:28rpx;font-size:32rpx;font-weight:700;border:none;background:linear-gradient(135deg,#FF6B8A,#FF8FAB);color:#fff;box-shadow:0 10rpx 36rpx rgba(255,107,138,.3);transition:transform .2s}
.p-btn:active{transform:scale(.97)}
.km{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.45);z-index:90;opacity:0;pointer-events:none;transition:opacity .3s}
.km.show{opacity:1;pointer-events:auto}
.kbox{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.85);z-index:91;background:#fff;border-radius:40rpx;padding:60rpx 48rpx;width:580rpx;box-sizing:border-box;opacity:0;pointer-events:none;transition:all .35s cubic-bezier(.32,.72,0,1);display:flex;flex-direction:column;align-items:center;text-align:center}
.kbox.show{opacity:1;pointer-events:auto;transform:translate(-50%,-50%) scale(1)}
.k-emoji{font-size:96rpx;margin-bottom:24rpx}
.k-title{font-size:34rpx;font-weight:800;color:#2D2B41;margin-bottom:16rpx;line-height:1.5}
.k-sub{font-size:26rpx;color:#B0A8C0;margin-bottom:40rpx;line-height:1.6}
.k-btns{display:flex;gap:20rpx;width:100%}
.k-cancel{flex:1;border-radius:40rpx;padding:24rpx;font-size:28rpx;font-weight:700;border:none;background:#F5F3F7;color:#8E8BA0}
.k-ok{flex:1;border-radius:40rpx;padding:24rpx;font-size:28rpx;font-weight:700;border:none;background:linear-gradient(135deg,#FF6B8A,#FF8FAB);color:#fff;box-shadow:0 8rpx 24rpx rgba(255,107,138,.25)}
.k-cancel:active,.k-ok:active{transform:scale(.96)}

/* ===== 经期操作栏 ===== */
.bm{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:84;opacity:0;pointer-events:none;transition:opacity .3s}
.bm.show{opacity:1;pointer-events:auto}
.bar{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:40rpx 40rpx 0 0;padding:16rpx 40rpx 80rpx;z-index:85;transform:translateY(100%);transition:transform .38s cubic-bezier(.32,.72,0,1)}
.bar.show{transform:translateY(0)}
.bar-h{width:64rpx;height:8rpx;border-radius:4rpx;background:#E0DDE5;margin:0 auto 28rpx}
.bar-row{display:flex;align-items:center;gap:16rpx;margin-bottom:12rpx}
.bar-dot{width:20rpx;height:20rpx;border-radius:50%;flex-shrink:0}
.bar-date{font-size:36rpx;font-weight:900;color:#2D2B41}
.bar-ph{font-size:26rpx;font-weight:700;color:#8E8BA0;background:#F5F3F7;padding:6rpx 18rpx;border-radius:16rpx}
.bar-info{font-size:28rpx;color:#555;display:block;margin-bottom:8rpx;padding-left:36rpx}
.bar-hint{font-size:26rpx;color:#aaa;display:block;margin-bottom:28rpx;padding-left:36rpx}
.bar-btn{width:100%;border-radius:60rpx;padding:28rpx;font-size:34rpx;font-weight:700;border:none;transition:transform .2s}
.bar-btn:active{transform:scale(.97)}
.bar-btn.pink{background:linear-gradient(135deg,#FF6B8A,#FF8FAB);color:#fff;box-shadow:0 10rpx 36rpx rgba(255,107,138,.3)}
.bar-cancel{display:block;text-align:center;font-size:28rpx;color:#aaa;margin-top:20rpx}

/* ===== 经期详情 ===== */
.dm{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:86;opacity:0;pointer-events:none;transition:opacity .3s}
.dm.show{opacity:1;pointer-events:auto}
.dv{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:40rpx 40rpx 0 0;padding:16rpx 40rpx 80rpx;z-index:87;transform:translateY(100%);transition:transform .38s cubic-bezier(.32,.72,0,1);max-height:80vh;overflow-y:auto}
.dv.show{transform:translateY(0)}
.dv-h{width:64rpx;height:8rpx;border-radius:4rpx;background:#E0DDE5;margin:0 auto 28rpx}
.dv-title-row{display:flex;align-items:center;gap:16rpx;margin-bottom:28rpx}
.dv-emoji{font-size:48rpx}
.dv-title{font-size:36rpx;font-weight:900;color:#2D2B41;flex:1}
.dv-status{font-size:24rpx;font-weight:700;padding:8rpx 20rpx;border-radius:20rpx}
.dv-section{background:#FAFAFA;border-radius:24rpx;padding:28rpx;margin-bottom:20rpx}
.dv-row{display:flex;justify-content:space-between;align-items:center;padding:12rpx 0}
.dv-row+.dv-row{border-top:1rpx solid #F0EDF5}
.dv-lbl{font-size:26rpx;color:#aaa}
.dv-val{font-size:28rpx;font-weight:700;color:#2D2B41}
.dv-days-highlight{font-size:32rpx;color:#FF6B8A;font-weight:900}
.timeline{padding:8rpx 0}
.tl-item{display:flex;gap:20rpx;min-height:80rpx}
.tl-left{display:flex;flex-direction:column;align-items:center;width:28rpx;flex-shrink:0}
.tl-dot{width:16rpx;height:16rpx;border-radius:50%;background:#EDE9F5;flex-shrink:0;margin-top:6rpx}
.tl-dot.active{background:#FF6B8A;box-shadow:0 0 10rpx rgba(255,107,138,.35)}
.tl-line{width:3rpx;flex:1;background:#F0EDF5;margin:4rpx 0;min-height:20rpx}
.tl-right{flex:1;padding-bottom:24rpx}
.tl-head{display:flex;align-items:center;gap:16rpx;margin-bottom:12rpx}
.tl-day{font-size:24rpx;font-weight:800;color:#FF6B8A;background:#FFF0F3;padding:4rpx 16rpx;border-radius:16rpx}
.tl-date{font-size:24rpx;color:#aaa}
.tl-moods{display:flex;flex-wrap:wrap;gap:10rpx;margin-bottom:10rpx}
.tl-mood{padding:8rpx 20rpx;border-radius:28rpx;background:#FFF0F5;color:#E8356B;font-size:22rpx;font-weight:700}
.tl-syms{display:flex;flex-wrap:wrap;gap:10rpx}
.tl-sym{padding:8rpx 20rpx;border-radius:28rpx;background:#FFF0F3;color:#E8356B;font-size:22rpx;font-weight:700}
.tl-no{font-size:22rpx;color:#D0CDD5;font-style:italic}
.dv-del{width:100%;border-radius:60rpx;padding:28rpx;font-size:30rpx;font-weight:700;border:none;background:#F5F3F7;color:#E8356B;margin-top:24rpx;transition:transform .2s}
.dv-del:active{transform:scale(.97)}

/* ===== 经期结束总结 ===== */
.endbox{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.85);z-index:91;background:#fff;border-radius:40rpx;padding:0 44rpx 48rpx;width:640rpx;box-sizing:border-box;opacity:0;pointer-events:none;transition:all .4s cubic-bezier(.32,.72,0,1);display:flex;flex-direction:column;align-items:center;max-height:90vh;overflow-y:auto}
.endbox.show{opacity:1;pointer-events:auto;transform:translate(-50%,-50%) scale(1)}
.end-h{width:64rpx;height:8rpx;border-radius:4rpx;background:#E0DDE5;margin:24rpx auto 20rpx}
.end-emoji{font-size:72rpx;margin-bottom:8rpx}
.end-title{font-size:36rpx;font-weight:900;color:#2D2B41;margin-bottom:24rpx}
.end-days-wrap{display:flex;align-items:baseline;gap:4rpx;margin-bottom:4rpx}
.end-days-num{font-size:88rpx;font-weight:900;color:#FF6B8A;line-height:1}
.end-days-unit{font-size:32rpx;font-weight:800;color:#FFB4C8}
.end-days-label{font-size:26rpx;color:#B0A8C0;margin-bottom:28rpx;display:block}
.end-card{width:100%;background:#FAFAFA;border-radius:24rpx;padding:8rpx 28rpx;margin-bottom:24rpx}
.end-row{display:flex;align-items:center;padding:16rpx 0;gap:12rpx}
.end-row+.end-row{border-top:1rpx solid #F0EDF5}
.end-row-icon{font-size:26rpx;flex-shrink:0;width:36rpx;text-align:center}
.end-row-label{font-size:26rpx;color:#999;flex:1}
.end-row-value{font-size:28rpx;font-weight:700;color:#2D2B41}
.end-advice-card{width:100%;border-radius:24rpx;padding:24rpx 28rpx;margin-bottom:16rpx;display:flex;gap:16rpx;align-items:flex-start}
.end-normal{background:#F0FAF4;border-left:6rpx solid #3BA55D}
.end-short{background:#FFF8EC;border-left:6rpx solid #FF9F43}
.end-long{background:#FFF2F0;border-left:6rpx solid #E85D5D}
.end-advice-icon{font-size:32rpx;flex-shrink:0;margin-top:2rpx}
.end-advice-text{font-size:26rpx;line-height:1.7;color:#444;flex:1}
.end-tips-card{width:100%;background:#F8F6FA;border-radius:24rpx;padding:24rpx 28rpx;margin-bottom:28rpx}
.end-tips-title{font-size:26rpx;font-weight:800;color:#2D2B41;display:block;margin-bottom:12rpx}
.end-tips-text{font-size:24rpx;color:#888;line-height:1.8;display:block;margin-bottom:8rpx}
.end-tips-text:last-child{margin-bottom:0}
.end-tips-em{color:#E85D5D;font-weight:600}
.end-btn{width:100%;border-radius:60rpx;padding:28rpx;font-size:30rpx;font-weight:700;border:none;background:#F5F3F7;color:#8E8BA0;transition:transform .2s}
.end-btn:active{transform:scale(.97)}
.d.future{opacity:.4;pointer-events:none}
