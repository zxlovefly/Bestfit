.me-wrap{height:100vh;}
.pad{padding:0 40rpx;}
.me-header{padding:120rpx 40rpx 40rpx;display:flex;flex-direction:column;align-items:center;text-align:center;}
.avatar{width:160rpx;height:160rpx;border-radius:50%;background:linear-gradient(135deg,var(--pink-light),var(--lavender-light));display:flex;align-items:center;justify-content:center;font-size:80rpx;position:relative;margin-bottom:24rpx;}
.avatar .badge{position:absolute;bottom:0;right:0;font-size:36rpx;}
.name{font-size:40rpx;font-weight:900;margin-bottom:8rpx;}
.level{font-size:24rpx;color:var(--text-muted);font-weight:700;}
.stat-box{display:flex;margin:0 40rpx 40rpx;background:#fff;border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);}
.s-item{flex:1;padding:32rpx;text-align:center;border-right:2rpx solid #F8F5FA;}
.s-item:last-child{border-right:none;}
.s-item .val{font-size:44rpx;font-weight:900;display:block;}
.s-item .label{font-size:20rpx;color:var(--text-muted);margin-top:8rpx;}
.chart-card{background:#fff;border-radius:var(--radius-lg);padding:36rpx;box-shadow:var(--shadow-sm);}
.c-title{font-size:26rpx;font-weight:800;display:block;margin-bottom:24rpx;}
.weight-chart{display:flex;align-items:flex-end;gap:6rpx;height:120rpx;}
.w-bar{flex:1;background:linear-gradient(to top,var(--pink),var(--pink-light));border-radius:8rpx 8rpx 0 0;}
.w-labels{display:flex;justify-content:space-between;margin-top:16rpx;}
.w-labels text{font-size:18rpx;color:var(--text-muted);}
.bar-chart{display:flex;align-items:flex-end;gap:16rpx;height:160rpx;}
.b-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:12rpx;}
.b-bar{width:100%;border-radius:12rpx 12rpx 0 0;min-height:8rpx;}
.b-col text{font-size:20rpx;color:var(--text-muted);font-weight:700;}
.menu-group{background:#fff;border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);margin-bottom:32rpx;}
.menu-item{display:flex;align-items:center;gap:28rpx;padding:32rpx;border-bottom:2rpx solid #F8F5FA;}
.menu-item:last-child{border-bottom:none;}
.menu-item .icon{font-size:40rpx;width:60rpx;text-align:center;}
.menu-item .label{flex:1;font-size:28rpx;font-weight:700;}
.menu-item .badge{font-size:20rpx;}