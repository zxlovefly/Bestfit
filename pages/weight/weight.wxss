page {
  background: #fef2f7;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.input {
  width: 100%;
  height: 120rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  background: #ff7fa8;
  color: #fff;
  font-size: 34rpx;
  border-radius: 24rpx;
  padding: 24rpx 0;
  margin-bottom: 40rpx;
  border: none;
}

.chart-title {
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.chart-box {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.canvas {
  width: 100%;
  height: 240rpx;
}