<view class="page">
  <view class="title">记录今日体重</view>
  <input class="input" type="digit" placeholder="请输入体重(kg)" bindinput="onWeight" value="{{weight}}"/>
  <button class="save-btn" bindtap="saveWeight">保存记录</button>

  <view class="chart-title">近7天体重变化</view>
  <view class="chart-box">
    <canvas canvas-id="weightCanvas" class="canvas"></canvas>
  </view>
</view>