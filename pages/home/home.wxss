/* ==================== 全局 ==================== */
.home-wrap{padding:40rpx;background:#FFF8F0;min-height:100vh;box-sizing:border-box}

/* ==================== 问候卡片 ==================== */
.greet-card{position:relative;border-radius:40rpx;padding:44rpx 40rpx 36rpx;margin-bottom:40rpx;overflow:hidden;box-shadow:0 8rpx 40rpx rgba(0,0,0,0.08);transition:background 0.6s ease}
.greet-card.morning{background:linear-gradient(135deg,#FFD4A8,#FFECD2,#FFF5E6)}
.greet-card.noon{background:linear-gradient(135deg,#FFE4B5,#FFF3D6,#FFFAF0)}
.greet-card.afternoon{background:linear-gradient(135deg,#D6EFFF,#E8F4FD,#F0F8FF)}
.greet-card.evening{background:linear-gradient(135deg,#F8B595,#FBC2C2,#E0C3D0)}
.greet-card.night{background:linear-gradient(135deg,#0F0C29,#1A1440,#302B63)}
.deco-layer{position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:0}
.greet-content{position:relative;z-index:1}
.greet-card.night .greet-main,.greet-card.night .greet-emoji{color:#E8E0FF}
.greet-card.night .greet-desc{color:rgba(200,190,240,0.8)}
.greet-card.night .meta-tag{background:rgba(255,255,255,0.1);color:rgba(220,210,255,0.85)}
.greet-card.night .weather-tip{background:rgba(255,255,255,0.08)}
.greet-card.night .wt-text{color:rgba(200,190,240,0.9)}
.greet-top-row{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12rpx}
.greet-left{display:flex;align-items:baseline;gap:12rpx;flex-wrap:wrap}
.greet-emoji{font-size:52rpx}
.greet-main{font-size:56rpx;font-weight:900;color:#2D2B41;letter-spacing:2rpx}
.greet-desc{font-size:28rpx;color:rgba(80,70,100,0.7);display:block;margin-bottom:24rpx;letter-spacing:1rpx}
.greet-meta{display:flex;flex-wrap:wrap;gap:12rpx;margin-bottom:16rpx}
.meta-tag{background:rgba(255,255,255,0.55);border-radius:20rpx;padding:8rpx 20rpx;font-size:22rpx;color:#5A5270;backdrop-filter:blur(8rpx)}
.weather-tag{background:rgba(255,255,255,0.7);font-weight:600}
.weather-placeholder{font-weight:700!important;animation:wpPulse 2.5s ease-in-out infinite}
.weather-placeholder text{color:#7C5CFC}
@keyframes wpPulse{0%,100%{opacity:0.65;transform:scale(1)}50%{opacity:1;transform:scale(1.04)}}
.weather-tip{background:rgba(255,255,255,0.45);border-radius:16rpx;padding:14rpx 20rpx;backdrop-filter:blur(6rpx);animation:tipFadeIn 0.8s ease-out 0.3s both}
.wt-text{font-size:24rpx;color:#5A5270;font-weight:500}
@keyframes tipFadeIn{from{opacity:0;transform:translateY(10rpx)}to{opacity:1;transform:translateY(0)}}

/* ===== 时间 fallback 星星 ===== */
.tw-star{position:absolute;background:#fff;border-radius:50%;animation:twinkle 3s ease-in-out infinite}
.ts1{width:4rpx;height:4rpx;top:10%;left:8%;animation-duration:2.5s}
.ts2{width:3rpx;height:3rpx;top:5%;left:22%;animation-duration:3.5s;animation-delay:0.8s}
.ts3{width:5rpx;height:5rpx;top:16%;left:35%;animation-duration:2.8s;animation-delay:1.5s}
.ts4{width:3rpx;height:3rpx;top:3%;left:48%;animation-duration:4s;animation-delay:0.3s}
.ts5{width:4rpx;height:4rpx;top:13%;left:62%;animation-duration:3.2s;animation-delay:2s}
.ts6{width:5rpx;height:5rpx;top:7%;left:75%;animation-duration:2.6s;animation-delay:1s}
.ts7{width:3rpx;height:3rpx;top:18%;left:88%;animation-duration:3.8s;animation-delay:0.5s}
.ts8{width:4rpx;height:4rpx;top:30%;left:15%;animation-duration:3s;animation-delay:1.8s}
.ts9{width:3rpx;height:3rpx;top:35%;left:80%;animation-duration:2.4s;animation-delay:0.7s}
.ts10{width:5rpx;height:5rpx;top:25%;left:52%;animation-duration:3.6s;animation-delay:1.2s}
@keyframes twinkle{0%,100%{opacity:0.15;transform:scale(1)}50%{opacity:1;transform:scale(1.4)}}

/* ===== 时间 fallback 流星 ===== */
.ss-wrap{position:absolute;pointer-events:none;opacity:0}
.ss-line{width:120rpx;height:2rpx;background:linear-gradient(90deg,#fff,rgba(255,255,255,0.35) 65%,transparent);transform:rotate(140deg);position:relative}
.ss-line::before{content:'';position:absolute;left:-4rpx;top:-4rpx;width:10rpx;height:10rpx;background:#fff;border-radius:50%;box-shadow:0 0 10rpx 4rpx rgba(255,255,255,0.7)}
.ssw1{top:8%;right:2%;animation:shoot1 7s ease-in-out 3s infinite}
@keyframes shoot1{0%,100%{opacity:0;transform:translate(0,0)}3%{opacity:1}18%{opacity:1;transform:translate(-600rpx,400rpx)}22%{opacity:0;transform:translate(-720rpx,480rpx)}}
.ssw2{top:4%;left:20%;animation:shoot2 10s ease-in-out 7s infinite}
.ssl2{width:90rpx;transform:rotate(155deg)}.ssl2::before{width:8rpx;height:8rpx}
@keyframes shoot2{0%,100%{opacity:0;transform:translate(0,0)}4%{opacity:1}16%{opacity:1;transform:translate(-420rpx,320rpx)}20%{opacity:0;transform:translate(-520rpx,400rpx)}}
.ssw3{top:12%;left:55%;animation:shoot3 12s ease-in-out 12s infinite}
.ssl3{width:100rpx;transform:rotate(130deg)}.ssl3::before{width:8rpx;height:8rpx}
@keyframes shoot3{0%,100%{opacity:0;transform:translate(0,0)}3%{opacity:1}13%{opacity:1;transform:translate(-500rpx,380rpx)}17%{opacity:0;transform:translate(-620rpx,470rpx)}}

/* ===== 时间 fallback 太阳光晕 ===== */
.sun-glow{position:absolute;width:300rpx;height:300rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,210,100,0.35),rgba(255,190,70,0.15) 40%,transparent 70%);top:-80rpx;right:-40rpx;animation:glowPulse 5s ease-in-out infinite}
@keyframes glowPulse{0%,100%{transform:scale(1);opacity:0.5}50%{transform:scale(1.18);opacity:0.85}}

/* ===== 时间 fallback 云朵 ===== */
.floating-cloud{position:absolute;opacity:0.22;animation:cloudDrift 25s linear infinite}
.fc1{top:22%;font-size:44rpx;animation-duration:28s}
.fc2{top:55%;font-size:60rpx;animation-duration:22s;animation-delay:-12s}
@keyframes cloudDrift{0%{left:-18%}100%{left:112%}}

/* ===== 时间 fallback 暖色光点 ===== */
.warm-dot{position:absolute;border-radius:50%;background:rgba(255,190,110,0.45);animation:warmFloat 6s ease-in-out infinite}
.wd1{width:10rpx;height:10rpx;top:25%;left:12%}
.wd2{width:14rpx;height:14rpx;top:50%;left:42%;animation-delay:-2s}
.wd3{width:8rpx;height:8rpx;top:18%;left:72%;animation-delay:-4s}
.wd4{width:12rpx;height:12rpx;top:60%;left:28%;animation-delay:-1s}
.wd5{width:10rpx;height:10rpx;top:38%;left:88%;animation-delay:-3s}
@keyframes warmFloat{0%,100%{transform:translateY(0) scale(1);opacity:0.25}50%{transform:translateY(-35rpx) scale(1.6);opacity:0.75}}

/* ===== 天气驱动问候卡片文字颜色 ===== */
.greet-card.greet-weather .greet-emoji,.greet-card.greet-weather .greet-main{color:#fff;text-shadow:0 2rpx 10rpx rgba(0,0,0,0.18)}
.greet-card.greet-weather .greet-desc{color:rgba(255,255,255,0.82);text-shadow:0 1rpx 6rpx rgba(0,0,0,0.12)}
.greet-card.greet-weather .meta-tag{background:rgba(255,255,255,0.22);color:rgba(255,255,255,0.92);backdrop-filter:blur(8rpx);-webkit-backdrop-filter:blur(8rpx)}
.greet-card.greet-weather .weather-tag{background:rgba(255,255,255,0.3)}
.greet-card.greet-weather .weather-placeholder text{color:#fff}
.greet-card.greet-weather .weather-tip{background:rgba(255,255,255,0.15)}
.greet-card.greet-weather .wt-text{color:rgba(255,255,255,0.92)}
.greet-card.greet-weather.greet-snowy .greet-emoji,.greet-card.greet-weather.greet-snowy .greet-main,.greet-card.greet-weather.greet-cloudy .greet-emoji,.greet-card.greet-weather.greet-cloudy .greet-main,.greet-card.greet-weather.greet-foggy .greet-emoji,.greet-card.greet-weather.greet-foggy .greet-main{color:#2D2B41;text-shadow:0 1rpx 4rpx rgba(255,255,255,0.5)}
.greet-card.greet-weather.greet-snowy .greet-desc,.greet-card.greet-weather.greet-cloudy .greet-desc,.greet-card.greet-weather.greet-foggy .greet-desc{color:rgba(45,43,65,0.7);text-shadow:none}
.greet-card.greet-weather.greet-snowy .meta-tag,.greet-card.greet-weather.greet-cloudy .meta-tag,.greet-card.greet-weather.greet-foggy .meta-tag{background:rgba(0,0,0,0.07);color:#455A64}
.greet-card.greet-weather.greet-snowy .weather-tag,.greet-card.greet-weather.greet-cloudy .weather-tag,.greet-card.greet-weather.greet-foggy .weather-tag{background:rgba(0,0,0,0.1)}
.greet-card.greet-weather.greet-snowy .weather-placeholder text,.greet-card.greet-weather.greet-cloudy .weather-placeholder text,.greet-card.greet-weather.greet-foggy .weather-placeholder text{color:#7C5CFC}
.greet-card.greet-weather.greet-snowy .weather-tip,.greet-card.greet-weather.greet-cloudy .weather-tip,.greet-card.greet-weather.greet-foggy .weather-tip{background:rgba(0,0,0,0.06)}
.greet-card.greet-weather.greet-snowy .wt-text,.greet-card.greet-weather.greet-cloudy .wt-text,.greet-card.greet-weather.greet-foggy .wt-text{color:rgba(45,43,65,0.8)}

/* ===== 天气驱动问候卡片特效 ===== */

/* 晴天 */
.greet-sun-glow-card{position:absolute;top:-60rpx;right:-30rpx;width:240rpx;height:240rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,220,80,0.45),rgba(255,200,50,0.15) 50%,transparent 70%);animation:greetSunGlow 4s ease-in-out infinite;pointer-events:none;z-index:0}
.greet-sun-halo-card{position:absolute;top:-30rpx;right:10rpx;width:160rpx;height:160rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,240,180,0.3),transparent 65%);animation:greetSunGlow 5s ease-in-out 1s infinite;pointer-events:none;z-index:0}
@keyframes greetSunGlow{0%,100%{transform:scale(1);opacity:0.5}50%{transform:scale(1.15);opacity:0.85}}
.greet-sun-dot-card{position:absolute;border-radius:50%;background:radial-gradient(circle,rgba(255,235,120,0.65),rgba(255,220,80,0.1));animation:greetSunDot 3.5s ease-in-out infinite alternate;pointer-events:none;z-index:0}
@keyframes greetSunDot{0%{transform:scale(0.6);opacity:0.25}100%{transform:scale(1.5);opacity:0.7}}

/* 雨天雨滴 */
.greet-raindrop{position:absolute;top:-40rpx;width:3rpx;background:linear-gradient(to bottom,transparent,rgba(200,225,255,0.4));border-radius:0 0 4rpx 4rpx;animation:greetRainFall linear infinite;pointer-events:none;z-index:0;will-change:transform,opacity;-webkit-backface-visibility:hidden;backface-visibility:hidden}
@keyframes greetRainFall{0%{transform:translateY(0);opacity:0}10%{opacity:0.1}30%{opacity:0.35}50%{opacity:0.42}75%{opacity:0.2}90%{opacity:0.06}100%{transform:translateY(110vh);opacity:0}}

/* 雨天玻璃水滴 */
.greet-card.greet-weather.greet-rainy::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 25% 35%,rgba(255,255,255,0.04),transparent 50%),radial-gradient(circle at 75% 65%,rgba(255,255,255,0.03),transparent 40%);pointer-events:none;z-index:0}
.greet-wet-overlay{position:absolute;bottom:0;left:0;right:0;height:35%;background:linear-gradient(to top,rgba(100,149,237,0.1),transparent);pointer-events:none;z-index:0}
.greet-glass-drop{position:absolute;border-radius:50%;background:radial-gradient(ellipse at 30% 25%,rgba(255,255,255,0.65),rgba(255,255,255,0.2) 30%,rgba(180,215,245,0.08) 60%,transparent);box-shadow:inset -1rpx -1rpx 2rpx rgba(255,255,255,0.12),0 1rpx 3rpx rgba(0,0,0,0.06);animation:greetGlassSlide linear infinite;pointer-events:none;z-index:0;will-change:transform,opacity;-webkit-backface-visibility:hidden;backface-visibility:hidden}
@keyframes greetGlassSlide{0%{opacity:0;transform:translateY(0) scale(0.15)}15%{opacity:0.2;transform:translateY(0) scale(0.55)}30%{opacity:0.45;transform:translateY(5rpx) scale(0.85)}45%{opacity:0.55;transform:translateY(12rpx) scale(1)}65%{opacity:0.35;transform:translateY(110rpx) scale(0.85)}85%{opacity:0.12;transform:translateY(220rpx) scale(0.5)}100%{opacity:0;transform:translateY(300rpx) scale(0.2)}}
.greet-streak{position:absolute;width:2rpx;background:linear-gradient(to bottom,rgba(255,255,255,0.25),rgba(255,255,255,0.02));border-radius:1rpx;animation:greetStreakFlow linear infinite;pointer-events:none;z-index:0}
.gs1{left:22%;height:80rpx;top:12%;animation-duration:5.5s}
.gs2{left:48%;height:100rpx;top:20%;animation-duration:7s;animation-delay:1.8s}
.gs3{left:72%;height:60rpx;top:8%;animation-duration:4.5s;animation-delay:3.5s}
.gs4{left:88%;height:70rpx;top:28%;animation-duration:6s;animation-delay:0.8s}
@keyframes greetStreakFlow{0%{opacity:0;transform:translateY(-20rpx)}20%{opacity:0.4}80%{opacity:0.1}100%{opacity:0;transform:translateY(180rpx)}}

/* 雨花涟漪 */
.greet-splash{position:absolute;bottom:8%;width:14rpx;height:7rpx;border-radius:50%;border:1.5rpx solid rgba(255,255,255,0.4);background:rgba(255,255,255,0.06);animation:splashRipple ease-out infinite;pointer-events:none;z-index:1;transform-origin:center center}
.gs-sp1{left:10%;animation-duration:2.4s;animation-delay:0s}
.gs-sp2{left:25%;animation-duration:2s;animation-delay:0.7s}
.gs-sp3{left:42%;animation-duration:2.6s;animation-delay:1.3s}
.gs-sp4{left:58%;animation-duration:2.2s;animation-delay:0.4s}
.gs-sp5{left:74%;animation-duration:2.1s;animation-delay:1s}
.gs-sp6{left:90%;animation-duration:2.5s;animation-delay:1.6s}
@keyframes splashRipple{0%{transform:scale(0);opacity:0}12%{transform:scale(0.4);opacity:0.65}35%{transform:scale(1.2);opacity:0.35}60%{transform:scale(1.8);opacity:0.12}100%{transform:scale(2.5);opacity:0}}

/* 雪天 */
.greet-card.greet-weather.greet-snowy::after{content:'';position:absolute;bottom:0;left:0;right:0;height:18%;background:linear-gradient(to top,rgba(255,255,255,0.2),transparent);pointer-events:none;z-index:0}
.greet-snow-ground{position:absolute;bottom:0;left:0;right:0;height:6%;background:rgba(255,255,255,0.35);border-radius:0 0 40rpx 40rpx;pointer-events:none;z-index:0}
.greet-snow-dot{position:absolute;top:-10rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,0.95),rgba(220,235,255,0.4));box-shadow:0 0 6rpx rgba(255,255,255,0.5);animation:greetSnowDrift ease-in-out infinite;pointer-events:none;z-index:0}
@keyframes greetSnowDrift{0%{transform:translate(0,0) rotate(0deg);opacity:0.7}25%{transform:translate(18rpx,80rpx) rotate(90deg);opacity:0.9}50%{transform:translate(-12rpx,170rpx) rotate(180deg);opacity:1}75%{transform:translate(22rpx,250rpx) rotate(270deg);opacity:0.6}100%{transform:translate(-8rpx,330rpx) rotate(360deg);opacity:0.15}}

/* 雷暴 */
.greet-lightning-card{position:absolute;inset:0;background:rgba(255,255,255,0.75);opacity:0;animation:greetLightningCard 14s linear infinite;pointer-events:none;z-index:2}
@keyframes greetLightningCard{0%,100%{opacity:0}82%{opacity:0}83%{opacity:0.5}84%{opacity:0}85%{opacity:0.18}86%{opacity:0}}
.greet-tdrop{position:absolute;top:-40rpx;width:3rpx;background:linear-gradient(to bottom,transparent,rgba(200,225,255,0.5));border-radius:0 0 4rpx 4rpx;animation:greetTFall linear infinite;pointer-events:none;z-index:1;will-change:transform,opacity;-webkit-backface-visibility:hidden;backface-visibility:hidden}
@keyframes greetTFall{0%{transform:translateY(0);opacity:0}10%{opacity:0.12}25%{opacity:0.38}40%{opacity:0.45}70%{opacity:0.25}90%{opacity:0.08}100%{transform:translateY(110vh);opacity:0}}

/* 多云 */
.greet-cloud-card{position:absolute;opacity:0.16;font-size:50rpx;animation:greetCloudCard linear infinite;pointer-events:none;z-index:0}
@keyframes greetCloudCard{0%{left:-20%}100%{left:110%}}

/* 雾天 */
.greet-fog-card{position:absolute;left:-15%;width:130%;height:80rpx;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4) 25%,rgba(255,255,255,0.6) 50%,rgba(255,255,255,0.4) 75%,transparent);filter:blur(10rpx);animation:greetFogCard ease-in-out infinite alternate;pointer-events:none;z-index:0}
@keyframes greetFogCard{0%{transform:translateX(-4%)}100%{transform:translateX(4%)}}

/* ==================== 热量环 ==================== */
.cal-card{background:#fff;border-radius:48rpx;padding:44rpx 40rpx 36rpx;margin-bottom:40rpx;box-shadow:0 8rpx 30rpx rgba(0,0,0,0.06);box-sizing:border-box;width:100%;overflow:hidden}
.cal-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24rpx}
.cal-header-left{display:flex;flex-direction:column;gap:8rpx}
.cal-title{font-size:36rpx;font-weight:900;color:#2D2B41;letter-spacing:2rpx}
.cal-subtitle{font-size:24rpx;color:#A8A5B8}
.no-profile-hint{color:#FFB347}
.cal-header-right{flex-shrink:0}
.goal-badge{padding:10rpx 24rpx;border-radius:30rpx;font-size:24rpx;font-weight:700}
.dual-ring-section{display:flex;flex-direction:column;align-items:center;padding:20rpx 0 12rpx}
.dr-label{font-size:24rpx;font-weight:700;color:#8B85A0;letter-spacing:2rpx}
.dr-label-top{margin-bottom:14rpx}
.dr-label-bottom{margin-top:14rpx;margin-bottom:24rpx}
.dual-ring-wrap{position:relative}
.dual-ring{width:300rpx;height:300rpx;border-radius:50%;position:relative;box-shadow:0 0 30rpx rgba(255,120,0,0.12),0 0 60rpx rgba(255,80,0,0.06)}
.dr-separator{position:absolute;top:50%;left:10rpx;right:10rpx;height:8rpx;background:linear-gradient(90deg,rgba(255,140,0,0.25),rgba(255,220,200,0.9) 25%,#fff 50%,rgba(200,220,255,0.9) 75%,rgba(142,197,252,0.25));transform:translateY(-4rpx);z-index:3;border-radius:4rpx;box-shadow:0 0 12rpx rgba(255,255,255,0.7)}
.dr-inner{position:absolute;top:32rpx;left:32rpx;right:32rpx;bottom:32rpx;border-radius:50%;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:inset 0 2rpx 12rpx rgba(0,0,0,0.04);z-index:2}
.dr-surplus-val{font-size:56rpx;font-weight:900;line-height:1.1}
.dr-surplus-unit{font-size:20rpx;color:#A8A5B8;margin-top:2rpx}
.dr-surplus-label{font-size:24rpx;font-weight:700;margin-top:4rpx}
.dr-legend{display:flex;gap:32rpx;margin-top:8rpx;flex-wrap:wrap;justify-content:center}
.dr-leg-item{display:flex;align-items:center;gap:8rpx}
.dr-leg-dot{width:16rpx;height:16rpx;border-radius:50%;flex-shrink:0}
.dr-leg-text{font-size:22rpx;color:#8B85A0}
.cal-warn-card{margin-top:28rpx;border-radius:20rpx;padding:24rpx;display:flex;align-items:flex-start;gap:16rpx}
.warn-low{background:linear-gradient(135deg,#FFF3E0,#FFF8E1);border:1rpx solid #FFE0B2}
.warn-high{background:linear-gradient(135deg,#FFEBEE,#FFF0F0);border:1rpx solid #FFCDD2}
.warn-icon{font-size:36rpx;flex-shrink:0;margin-top:2rpx}
.warn-info{flex:1;display:flex;flex-direction:column;gap:6rpx}
.warn-title{font-size:26rpx;font-weight:700;color:#2D2B41}
.warn-desc{font-size:22rpx;color:#8B85A0;line-height:1.6}
.cal-setup-prompt{margin-top:32rpx;background:linear-gradient(135deg,#FFF5E6,#FFF0F5);border-radius:24rpx;padding:32rpx;display:flex;align-items:center;gap:20rpx}
.np-icon{font-size:52rpx;flex-shrink:0}
.np-content{flex:1;display:flex;flex-direction:column;gap:6rpx}
.np-title{font-size:28rpx;font-weight:700;color:#2D2B41}
.np-desc{font-size:22rpx;color:#A8A5B8;line-height:1.5}
.np-btn{flex-shrink:0;background:linear-gradient(135deg,#FFB4C2,#FF8FAB);color:#fff;font-size:26rpx;font-weight:700;padding:16rpx 32rpx;border-radius:30rpx;text-align:center}
.np-btn:active{transform:scale(0.95)}
.tdee-toggle{margin-top:28rpx;padding:20rpx 0;display:flex;align-items:center;justify-content:space-between;border-top:1rpx solid #F0ECF5}
.tdee-toggle-label{font-size:26rpx;color:#6B6880;font-weight:600}
.tdee-toggle-arrow{width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;font-size:32rpx;color:#A8A5B8;transform:rotate(90deg);transition:transform 0.3s ease}
.tdee-toggle-arrow.arrow-up{transform:rotate(-90deg)}
.tdee-details{max-height:0;overflow:hidden;transition:max-height 0.4s cubic-bezier(0.4,0,0.2,1)}
.tdee-details.expanded{max-height:1000rpx}
.tdee-section{padding:20rpx 0 8rpx}
.tdee-row{display:flex;align-items:center;padding:18rpx 0;gap:16rpx}
.tdee-icon-wrap{width:56rpx;height:56rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;flex-shrink:0}
.tdee-row-info{flex:1;display:flex;flex-direction:column;gap:2rpx;min-width:0}
.tdee-label{font-size:26rpx;color:#2D2B41;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tdee-desc{font-size:20rpx;color:#C0BDD0}
.tdee-row-bold .tdee-label{font-weight:800}
.tdee-row-target .tdee-label{font-size:28rpx;font-weight:900}
.tdee-value{font-size:30rpx;font-weight:700;color:#2D2B41;text-align:right;min-width:90rpx;flex-shrink:0;font-variant-numeric:tabular-nums}
.tdee-value.accent{font-size:34rpx;color:#7C5CFC;font-weight:900}
.tdee-unit{font-size:22rpx;color:#A8A5B8;min-width:48rpx;flex-shrink:0;text-align:left}
.tdee-divider{height:1rpx;background:#F0ECF5;margin:8rpx 0}
.tdee-divider.thick{height:3rpx;background:linear-gradient(90deg,#F0ECF5,#E8D5F5,#F0ECF5);margin:12rpx 0}

/* ==================== 快捷入口 ==================== */
.sc-title{font-size:32rpx;color:#A8A5B8;margin-bottom:24rpx;font-weight:600}
.sc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24rpx;margin-bottom:40rpx}
.sc-card{position:relative;border-radius:28rpx;overflow:hidden}
.sc-liquid{position:absolute;top:-50%;left:-50%;width:200%;height:200%;animation:liquidSpin 4s linear infinite}
@keyframes liquidSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.sc-card-water .sc-liquid{background:conic-gradient(#4FC3F7,#29B6F6,#03A9F4,#0288D1,#039BE5,#4FC3F7);animation-duration:3.5s}
.sc-card-diet .sc-liquid{background:conic-gradient(#FFD54F,#FFCA28,#FFB300,#FFA000,#FFB300,#FFD54F);animation-duration:4s}
.sc-card-sport .sc-liquid{background:conic-gradient(#81C784,#66BB6A,#4CAF50,#388E3C,#4CAF50,#81C784);animation-duration:4.5s}
.sc-card-poo .sc-liquid{background:conic-gradient(#BCAAA4,#A1887F,#8D6E63,#A1887F,#D7CCC8,#BCAAA4);animation-duration:5s}
.sc-body{position:relative;z-index:1;margin:4rpx;background:#fff;border-radius:24rpx;padding:32rpx 24rpx;display:flex;align-items:center;gap:20rpx;transition:transform 0.2s ease}
.sc-card:active .sc-body{transform:scale(0.97)}
.sc-icon-wrap{width:88rpx;height:88rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sc-emoji{font-size:52rpx}
.sc-ib-water{background:#E3F2FD}
.sc-ib-diet{background:#FFF3E0}
.sc-ib-sport{background:#E8F5E9}
.sc-ib-poo{background:#EFEBE9}
.sc-info{flex:1;min-width:0}
.sc-name{font-size:30rpx;font-weight:700;color:#2D2B41;display:block;margin-bottom:4rpx}
.sc-desc{font-size:24rpx;color:#A8A5B8;display:block}
.sc-done{color:#4CAF50;font-weight:600}

/* ==================== 女性健康 ==================== */
.wc-card{background:linear-gradient(135deg,#FCE4EC 0%,#F8BBD0 50%,#FCE4EC 100%);border-radius:28rpx;padding:32rpx;margin-bottom:40rpx;display:flex;align-items:center;justify-content:space-between;border:2rpx solid #F8BBD0;box-shadow:0 4rpx 20rpx rgba(236,64,122,0.08);transition:transform 0.2s ease}
.wc-card:active{transform:scale(0.98)}
.wc-left{display:flex;align-items:center;gap:20rpx}
.wc-icon-wrap{width:80rpx;height:80rpx;border-radius:22rpx;background:rgba(255,255,255,0.7);display:flex;align-items:center;justify-content:center}
.wc-emoji{font-size:48rpx}
.wc-info{flex:1}
.wc-name{font-size:32rpx;font-weight:800;color:#C2185B;display:block;margin-bottom:4rpx}
.wc-desc{font-size:24rpx;color:#E91E63;opacity:0.7;display:block}
.wc-arrow{font-size:40rpx;color:#E91E63;opacity:0.5;flex-shrink:0}

/* ==================== 今日计划 ==================== */
.plan-title{font-size:32rpx;color:#A8A5B8;margin-bottom:24rpx}
.plan-list{display:flex;flex-direction:column;gap:20rpx}
.plan-item{background:#fff;border-radius:28rpx;padding:36rpx;display:flex;align-items:center;gap:24rpx;box-sizing:border-box;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.04);transition:all 0.3s ease;overflow:visible}
.plan-item:active{transform:translateY(-2rpx)}
.p-info{flex:1}
.p-name{font-size:36rpx;font-weight:700;display:block;margin-bottom:8rpx}
.p-desc{font-size:26rpx;color:#A8A5B8;display:block}
.p-icon-area{position:relative;width:80rpx;text-align:center;flex-shrink:0;overflow:visible}
.burst-wrap{position:absolute;top:40rpx;left:40rpx;width:0;height:0;z-index:50;pointer-events:none}
.bf{position:absolute;font-size:40rpx;top:0;left:0;opacity:0;pointer-events:none}
.icon-bounce{animation:iconBounce 0.5s ease}
@keyframes iconBounce{0%{transform:scale(1)}30%{transform:scale(1.4)}60%{transform:scale(0.9)}100%{transform:scale(1)}}
.bf0{animation:fb0 1.2s ease-out 0s forwards}
.bf1{animation:fb1 1.2s ease-out 0.06s forwards}
.bf2{animation:fb2 1.2s ease-out 0.12s forwards}
.bf3{animation:fb3 1.2s ease-out 0.03s forwards}
.bf4{animation:fb4 1.2s ease-out 0.09s forwards}
.bf5{animation:fb5 1.2s ease-out 0.15s forwards}
.bf6{animation:fb6 1.2s ease-out 0.08s forwards}
.bf7{animation:fb7 1.2s ease-out 0.04s forwards}
.bf8{animation:fb8 1.2s ease-out 0.11s forwards}
.bf9{animation:fb9 1.2s ease-out 0.07s forwards}
@keyframes fb0{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(-70rpx,-220rpx) scale(1.4) rotate(30deg);opacity:0}}
@keyframes fb1{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(50rpx,-240rpx) scale(1.2) rotate(-25deg);opacity:0}}
@keyframes fb2{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(160rpx,-130rpx) scale(1.5) rotate(40deg);opacity:0}}
@keyframes fb3{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(190rpx,20rpx) scale(1.3) rotate(-35deg);opacity:0}}
@keyframes fb4{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(130rpx,150rpx) scale(1.2) rotate(25deg);opacity:0}}
@keyframes fb5{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(10rpx,200rpx) scale(1.4) rotate(-30deg);opacity:0}}
@keyframes fb6{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(-140rpx,140rpx) scale(1.3) rotate(45deg);opacity:0}}
@keyframes fb7{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(-190rpx,-20rpx) scale(1.5) rotate(-25deg);opacity:0}}
@keyframes fb8{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(-120rpx,-170rpx) scale(1.2) rotate(35deg);opacity:0}}
@keyframes fb9{0%{transform:translate(0,0) scale(0) rotate(0deg);opacity:1}15%{opacity:1}100%{transform:translate(110rpx,-190rpx) scale(1.4) rotate(-40deg);opacity:0}}
.mini-btns{display:flex;gap:16rpx;margin-top:20rpx;flex-wrap:wrap}
.mini-btn{display:flex;align-items:center;justify-content:center;width:76rpx;height:76rpx;border-radius:50%;font-size:36rpx;transition:all 0.2s ease}
.mini-btn:active{transform:scale(0.8)}
.food-item{background:linear-gradient(135deg,#FFF8F0,#FFF3E6,#FFFAF2);border:2rpx solid #FFE4C9}
.food-main-icon{font-size:64rpx;width:80rpx;text-align:center}
.food-btn{background:rgba(255,200,120,0.3);border:2rpx solid rgba(255,200,120,0.5)}
.food-btn:active{background:rgba(255,180,80,0.6)}
.sport-item{background:linear-gradient(135deg,#F0FFFE,#E6FFF8,#F2FFFC);border:2rpx solid #C2F5EA}
.sport-main-icon{font-size:64rpx;width:80rpx;text-align:center}
.sport-btn{background:rgba(130,220,200,0.3);border:2rpx solid rgba(130,220,200,0.5)}
.sport-btn:active{background:rgba(100,200,180,0.6)}
.mood-item{background:linear-gradient(135deg,#FFF5F7,#FFF0F5,#FFF8FC);border:2rpx solid #FFE0EA}
.mood-main-icon{font-size:64rpx;width:80rpx;text-align:center}
.mood-btn{background:rgba(255,182,193,0.3);border:2rpx solid rgba(255,182,193,0.5)}
.mood-btn:active{background:rgba(255,182,193,0.6)}
.sleep-item{background:linear-gradient(135deg,#F0F0FF,#EDE8FF,#F5F0FF);border:2rpx solid #DDD6FF}
.sleep-main-icon{font-size:64rpx;width:80rpx;text-align:center}
.sleep-btn{background:rgba(199,206,234,0.3);border:2rpx solid rgba(199,206,234,0.5)}
.sleep-btn:active{background:rgba(199,206,234,0.6)}

/* ==================== 天气详情弹窗 ==================== */
.wd-mask{position:fixed;inset:0;z-index:300}
.wd-panel{width:100%;height:100vh;position:relative;overflow:hidden}
.wd-anim-layer{position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:0}
.wd-close{position:fixed;top:60rpx;right:40rpx;width:72rpx;height:72rpx;display:flex;align-items:center;justify-content:center;font-size:40rpx;z-index:10;opacity:0.8}
.wd-close:active{opacity:0.5}
.wd-head{text-align:center;padding:80rpx 40rpx 40rpx;position:relative;z-index:1}
.wd-city{font-size:32rpx;font-weight:600;opacity:0.85;display:block;margin-bottom:12rpx;letter-spacing:4rpx}
.wd-temp-row{display:flex;align-items:center;justify-content:center;gap:16rpx;margin-bottom:8rpx}
.wd-big-icon{font-size:80rpx}
.wd-big-temp{font-size:140rpx;font-weight:100;line-height:1;letter-spacing:-4rpx}
.wd-desc{font-size:30rpx;opacity:0.85;display:block;margin-bottom:8rpx}
.wd-feels{font-size:24rpx;opacity:0.65;display:block;margin-bottom:20rpx}
.wd-range{display:flex;align-items:center;justify-content:center;gap:16rpx;font-size:24rpx;opacity:0.75}
.wd-range-bar{width:200rpx;height:6rpx;border-radius:3rpx;background:rgba(255,255,255,0.3);overflow:hidden}
.wd-range-fill{width:60%;height:100%;border-radius:3rpx;background:rgba(255,255,255,0.7)}

/* 5格网格 */
.wd-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14rpx;padding:0 32rpx;margin-bottom:16rpx;position:relative;z-index:1}
.wd-cell{background:rgba(255,255,255,0.12);backdrop-filter:blur(16rpx);border-radius:24rpx;padding:24rpx 8rpx;text-align:center;border:1rpx solid rgba(255,255,255,0.1)}
.wd-ci{font-size:36rpx;display:block;margin-bottom:8rpx}
.wd-cv{font-size:26rpx;font-weight:800;display:block;margin-bottom:4rpx;color:#fff}
.wd-cl{font-size:18rpx;opacity:0.65;display:block;color:#fff}

/* 生活建议 */
.wa-list{padding:0 40rpx;position:relative;z-index:1}
.wa-card{background:rgba(255,255,255,0.1);backdrop-filter:blur(20rpx);border:1rpx solid rgba(255,255,255,0.1);border-radius:24rpx;padding:28rpx 24rpx;margin-bottom:16rpx;display:flex;align-items:flex-start;gap:20rpx;animation:waFadeIn 0.45s ease-out both}
.wa-card:nth-child(1){animation-delay:0.08s}
.wa-card:nth-child(2){animation-delay:0.16s}
.wa-card:nth-child(3){animation-delay:0.24s}
.wa-card:nth-child(4){animation-delay:0.32s}
.wa-card:nth-child(5){animation-delay:0.40s}
.wa-card:nth-child(6){animation-delay:0.48s}
@keyframes waFadeIn{from{opacity:0;transform:translateY(24rpx)}to{opacity:1;transform:translateY(0)}}
.wa-icon{font-size:44rpx;flex-shrink:0;margin-top:2rpx}
.wa-info{flex:1;min-width:0}
.wa-name{font-size:26rpx;font-weight:700;color:#fff;display:block;margin-bottom:6rpx}
.wa-text{font-size:24rpx;color:rgba(255,255,255,0.75);line-height:1.7;display:block}
.wd-footer{text-align:center;padding:40rpx 0 20rpx;position:relative;z-index:1}
.wd-ft{font-size:20rpx;opacity:0.35;color:#fff}

/* 天气详情晴天 */
.sun-core{position:absolute;top:-60rpx;right:60rpx;width:200rpx;height:200rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,220,80,0.5),rgba(255,200,50,0.2) 50%,transparent 70%);animation:sunCorePulse 4s ease-in-out infinite}
@keyframes sunCorePulse{0%,100%{transform:scale(1);opacity:0.6}50%{transform:scale(1.2);opacity:1}}
.sun-ray{position:absolute;top:40rpx;right:130rpx;width:4rpx;height:80rpx;background:rgba(255,220,100,0.4);border-radius:2rpx;transform-origin:center 160rpx;animation:sunRayRotate 12s linear infinite}
.sr1{transform:rotate(0deg) translateY(-80rpx)}
.sr2{transform:rotate(45deg) translateY(-80rpx);animation-delay:-1.5s}
.sr3{transform:rotate(90deg) translateY(-80rpx);animation-delay:-3s}
.sr4{transform:rotate(135deg) translateY(-80rpx);animation-delay:-4.5s}
.sr5{transform:rotate(180deg) translateY(-80rpx);animation-delay:-6s}
.sr6{transform:rotate(225deg) translateY(-80rpx);animation-delay:-7.5s}
.sr7{transform:rotate(270deg) translateY(-80rpx);animation-delay:-9s}
.sr8{transform:rotate(315deg) translateY(-80rpx);animation-delay:-10.5s}
@keyframes sunRayRotate{0%{opacity:0.2}50%{opacity:0.7}100%{opacity:0.2}}
.sun-particle{position:absolute;border-radius:50%;background:rgba(255,220,100,0.5);animation:sunPartFloat 4s ease-in-out infinite}
@keyframes sunPartFloat{0%,100%{transform:translateY(0) scale(1);opacity:0.2}50%{transform:translateY(-30rpx) scale(1.6);opacity:0.7}}

/* 天气详情雨天雨滴 */
.raindrop{position:absolute;top:-40rpx;width:3rpx;background:linear-gradient(to bottom,transparent,rgba(180,215,255,0.5));border-radius:0 0 4rpx 4rpx;animation:rainFall linear infinite;will-change:transform,opacity;-webkit-backface-visibility:hidden;backface-visibility:hidden}
@keyframes rainFall{0%{transform:translateY(0);opacity:0}10%{opacity:0.12}25%{opacity:0.38}40%{opacity:0.48}65%{opacity:0.3}85%{opacity:0.1}100%{transform:translateY(110vh);opacity:0}}

/* 天气详情雨花 */
.wd-splash{position:absolute;bottom:18%;width:14rpx;height:7rpx;border-radius:50%;border:1.5rpx solid rgba(255,255,255,0.35);background:rgba(255,255,255,0.05);animation:splashRipple ease-out infinite;pointer-events:none;z-index:1;transform-origin:center center}
.wd-sp1{left:6%;animation-duration:2.5s;animation-delay:0s}
.wd-sp2{left:16%;animation-duration:2.1s;animation-delay:0.5s}
.wd-sp3{left:30%;animation-duration:2.4s;animation-delay:1.1s}
.wd-sp4{left:44%;animation-duration:2.7s;animation-delay:0.3s}
.wd-sp5{left:58%;animation-duration:2.2s;animation-delay:0.8s}
.wd-sp6{left:72%;animation-duration:2.5s;animation-delay:1.4s}
.wd-sp7{left:84%;animation-duration:2s;animation-delay:0.6s}
.wd-sp8{left:94%;animation-duration:2.3s;animation-delay:1.2s}

/* 天气详情雷暴闪电 */
.lightning-flash{position:absolute;inset:0;pointer-events:none;animation:lightningFlash 14s infinite}
@keyframes lightningFlash{0%,100%{background:transparent}82%{background:transparent}83%{background:rgba(255,255,255,0.3)}84%{background:transparent}}

/* 天气详情雪天 */
.snowflake{position:absolute;top:-20rpx;background:rgba(255,255,255,0.85);border-radius:50%;box-shadow:0 0 6rpx rgba(255,255,255,0.4);animation:snowFall linear infinite}
@keyframes snowFall{0%{transform:translate(0,0);opacity:0}10%{opacity:1}50%{transform:translate(25rpx,50vh)}90%{opacity:0.7}100%{transform:translate(-15rpx,110vh);opacity:0}}

/* 天气详情多云 */
.wd-cloud{position:absolute;opacity:0.2;animation:wdCloudDrift linear infinite}
.wd-cloud::before{content:'☁️'}
@keyframes wdCloudDrift{0%{left:-25%}100%{left:125%}}

/* 天气详情雾天 */
.fog-band{position:absolute;left:-20%;width:140%;height:120rpx;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.6) 30%,rgba(255,255,255,0.8) 50%,rgba(255,255,255,0.6) 70%,transparent);animation:fogDrift ease-in-out infinite;filter:blur(8rpx)}
@keyframes fogDrift{0%,100%{transform:translateX(0)}50%{transform:translateX(40rpx)}}

/* ==================== 央视天气按钮 ==================== */
.astro-link-btn{position:relative;border-radius:20rpx;overflow:hidden;background:linear-gradient(135deg,rgba(91,155,213,0.18),rgba(108,142,239,0.12),rgba(255,180,194,0.1));border:1rpx solid rgba(255,255,255,0.12);backdrop-filter:blur(20rpx);-webkit-backdrop-filter:blur(20rpx);transition:all 0.3s ease}
.astro-link-btn:active{transform:scale(0.97);background:linear-gradient(135deg,rgba(91,155,213,0.3),rgba(108,142,239,0.2),rgba(255,180,194,0.18))}
.astro-link-glow{position:absolute;top:-40rpx;right:-40rpx;width:180rpx;height:180rpx;border-radius:50%;background:radial-gradient(circle,rgba(108,142,239,0.2),transparent 70%);animation:astroGlow 4s ease-in-out infinite;pointer-events:none;z-index:0}
@keyframes astroGlow{0%,100%{transform:scale(1);opacity:0.4}50%{transform:scale(1.3);opacity:0.8}}
.astro-link-content{position:relative;z-index:1;display:flex;align-items:center;gap:20rpx;padding:28rpx 24rpx}
.astro-link-icon-wrap{width:72rpx;height:72rpx;border-radius:50%;background:linear-gradient(135deg,rgba(91,155,213,0.25),rgba(108,142,239,0.15));display:flex;align-items:center;justify-content:center;flex-shrink:0;animation:astroIconSpin 8s linear infinite}
@keyframes astroIconSpin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
.astro-link-icon{font-size:36rpx;display:block;animation:astroIconCounter 8s linear infinite}
@keyframes astroIconCounter{0%{transform:rotate(0deg)}100%{transform:rotate(-360deg)}}
.astro-link-info{flex:1;display:flex;flex-direction:column;gap:6rpx;min-width:0}
.astro-link-title{font-size:28rpx;font-weight:700;color:rgba(255,255,255,0.95);display:block;letter-spacing:1rpx}
.astro-link-desc{font-size:22rpx;color:rgba(255,255,255,0.55);display:block}
.astro-link-arrow-wrap{width:56rpx;height:56rpx;border-radius:50%;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.3s ease}
.astro-link-btn:active .astro-link-arrow-wrap{background:rgba(255,255,255,0.2);transform:translateX(4rpx)}
.astro-link-arrow{font-size:36rpx;color:rgba(255,255,255,0.7);font-weight:300;line-height:1}

/* ==================== 可爱提示弹窗 ==================== */
.cute-mask{position:fixed;inset:0;background:rgba(0,0,0,0.3);z-index:500;animation:cuteMaskIn 0.25s ease}
@keyframes cuteMaskIn{from{opacity:0}to{opacity:1}}
.cute-popup{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:520rpx;background:#fff;border-radius:44rpx;padding:52rpx 36rpx 40rpx;z-index:501;overflow:hidden;text-align:center;animation:cutePopIn 0.5s cubic-bezier(0.34,1.56,0.64,1)}
@keyframes cutePopIn{from{opacity:0;transform:translate(-50%,-50%) scale(0.55) translateY(60rpx)}to{opacity:1;transform:translate(-50%,-50%) scale(1) translateY(0)}}
.cute-deco{position:absolute;inset:0;pointer-events:none;z-index:0}
.cute-sparkle{position:absolute;animation:cuteSparkle 3s ease-in-out infinite}
.cs1{top:16rpx;left:28rpx;font-size:24rpx}
.cs2{top:40rpx;right:32rpx;font-size:20rpx;animation-delay:0.8s}
.cs3{bottom:80rpx;left:22rpx;font-size:18rpx;animation-delay:1.5s}
.cs4{bottom:50rpx;right:26rpx;font-size:22rpx;animation-delay:2.2s}
@keyframes cuteSparkle{0%,100%{opacity:0.15;transform:translateY(0) scale(1)}50%{opacity:1;transform:translateY(-12rpx) scale(1.25)}}
.cute-blob{position:absolute;border-radius:50%;pointer-events:none;z-index:0}
.cute-blob1{top:-70rpx;right:-50rpx;width:240rpx;height:240rpx;background:radial-gradient(circle,rgba(255,180,194,0.2),transparent 70%)}
.cute-blob2{bottom:-40rpx;left:-40rpx;width:180rpx;height:180rpx;background:radial-gradient(circle,rgba(180,200,255,0.15),transparent 70%)}
.cute-emoji{font-size:100rpx;display:block;margin-bottom:16rpx;position:relative;z-index:1;animation:cuteBounce 2.5s ease-in-out infinite}
