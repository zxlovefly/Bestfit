<view class="page">

<!-- 状态栏 -->
<view style="height:{{statusBarH}}px;background:#faf9f6;"></view>

<!-- 头部 -->
<view class="head">
  <view class="back-btn" bindtap="goBack"><text>‹</text></view>
  <text class="head-title">添加运动</text>
  <view class="head-right"></view>
</view>

<!-- 搜索栏 -->
<view class="search-wrap">
  <view class="search-box">
    <text class="s-icon">🔍</text>
    <input class="s-input"
           placeholder="搜索运动项目"
           placeholder-class="s-placeholder"
           value="{{searchKey}}"
           bindinput="onSearchInput"
           confirm-type="search" />
    <text wx:if="{{searchKey}}" class="s-clear" bindtap="clearSearch">✕</text>
  </view>
</view>

<!-- ===== 搜索结果模式 ===== -->
<scroll-view wx:if="{{isSearching}}" class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="list-pad">
    <block wx:if="{{searchResults.length}}">
      <view class="result-hint">找到 {{searchResults.length}} 项运动</view>
      <view wx:for="{{searchResults}}" wx:key="id"
            class="sport-row {{selectedId===item.id?'sel':''}}"
            bindtap="onTapSport" data-id="{{item.id}}">
        <view class="sr-emoji">{{item.emoji}}</view>
        <view class="sr-info">
          <text class="sr-name">{{item.name}}</text>
          <text class="sr-meta">{{item.catName}} · 约{{item.cal60}}千卡/小时</text>
        </view>
        <view class="radio {{selectedId===item.id?'on':''}}">
          <text wx:if="{{selectedId===item.id}}" class="radio-check">✓</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty-box">
      <text class="empty-ico">🔍</text>
      <text class="empty-txt">未找到「{{searchKey}}」相关运动</text>
      <text class="empty-sub">试试其他关键词，或前往自定义添加</text>
    </view>
  </view>
</scroll-view>

<!-- ===== 分类浏览模式 ===== -->
<view wx:else class="content-row">

  <!-- 左侧分类栏 -->
  <scroll-view class="sidebar" scroll-y enhanced show-scrollbar="{{false}}"
               scroll-into-view="cat-{{activeCategory}}" scroll-with-animation>
    <view wx:for="{{categories}}" wx:key="id"
          id="cat-{{item.id}}"
          class="sb-item {{activeCategory===item.id?'act':''}}"
          bindtap="switchCategory" data-id="{{item.id}}">
      <text class="sb-ico">{{item.icon}}</text>
      <text class="sb-txt">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 右侧运动列表 -->
  <scroll-view class="sport-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="list-pad">

      <!-- 自定义添加按钮 -->
      <view wx:if="{{activeCategory==='custom'}}" class="add-btn" bindtap="showAddCustom">
        <text class="add-plus">+</text>
        <text>添加自定义运动</text>
      </view>

      <!-- 运动卡片 -->
      <view wx:for="{{currentSports}}" wx:key="id"
            class="sport-row {{selectedId===item.id?'sel':''}}"
            bindtap="onTapSport" data-id="{{item.id}}">
        <view class="sr-emoji">{{item.emoji}}</view>
        <view class="sr-info">
          <text class="sr-name">{{item.name}}</text>
          <text class="sr-meta">约{{item.cal60}}千卡/小时</text>
        </view>
        <view class="radio {{selectedId===item.id?'on':''}}">
          <text wx:if="{{selectedId===item.id}}" class="radio-check">✓</text>
        </view>
        <!-- 自定义删除 -->
        <view wx:if="{{activeCategory==='custom'}}"
              class="del-btn" catchtap="deleteCustom" data-id="{{item.id}}">✕</view>
      </view>

      <!-- 自定义空状态 -->
      <view wx:if="{{currentSports.length===0 && activeCategory==='custom'}}" class="empty-box">
        <text class="empty-ico">✏️</text>
        <text class="empty-txt">暂无自定义运动</text>
        <text class="empty-sub">点击上方按钮添加你常做的运动</text>
      </view>

    </view>
  </scroll-view>
</view>

<!-- ===== 底部时长面板 ===== -->
<view class="panel-mask {{showPanel?'show':''}}" bindtap="closePanel"></view>
<view class="panel {{showPanel?'show':''}}">
  <view class="panel-handle"><view class="handle-bar"></view></view>
  <view class="panel-body">
    <!-- 已选运动 -->
    <view class="ps-row">
      <view class="ps-emoji">{{selectedSport.emoji}}</view>
      <view class="ps-info">
        <text class="ps-name">{{selectedSport.name}}</text>
        <text class="ps-cal">约{{selectedSport.cal60}}千卡/小时</text>
      </view>
    </view>

    <!-- 时长选择 -->
    <text class="panel-label">运动时长</text>
    <view class="dur-presets">
      <view wx:for="{{durPresets}}" wx:key="*this"
            class="dur-pill {{min==item?'on':''}}"
            bindtap="tapPreset" data-val="{{item}}">
        {{item}}分钟
      </view>
    </view>
    <view class="dur-input">
      <text class="dur-input-icon">⏱️</text>
      <input type="number" placeholder="自定义时长（分钟）" value="{{min}}" bindinput="inputMin" />
    </view>

    <!-- ★ 时间功能：开始/结束时间选择 -->
    <text class="panel-label">运动时间</text>
    <view class="time-row">
      <view class="time-col">
        <text class="time-tag">开始</text>
        <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange">
          <view class="time-pick-btn {{startTime ? 'has-val' : ''}}">
            <text class="tpb-icon">🕐</text>
            <text class="tpb-text">{{startTime || '选择时间'}}</text>
          </view>
        </picker>
      </view>
      <view class="time-mid">
        <view class="time-arrow-line"></view>
        <text class="time-arrow-icon">→</text>
        <view class="time-arrow-line"></view>
      </view>
      <view class="time-col">
        <text class="time-tag">结束</text>
        <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange">
          <view class="time-pick-btn {{endTime ? 'has-val' : ''}}">
            <text class="tpb-icon">🕑</text>
            <text class="tpb-text">{{endTime || '选择时间'}}</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 预估热量 -->
    <view wx:if="{{previewCal>0}}" class="preview">
      <text class="pv-label">预计消耗</text>
      <text class="pv-cal">{{previewCal}}</text>
      <text class="pv-unit">千卡</text>
    </view>

    <!-- 保存 -->
    <view class="save-btn" bindtap="save">
      <text>保存运动记录</text>
    </view>
  </view>
</view>

<!-- ===== 自定义运动弹窗 ===== -->
<view wx:if="{{showCustomModal}}" class="modal-mask" bindtap="hideModal">
  <view class="modal" catchtap="preventBubble">
    <text class="modal-tt">添加自定义运动</text>
    <view class="modal-field">
      <text class="mf-label">运动名称</text>
      <input class="mf-input" placeholder="如：飞盘高尔夫" value="{{customName}}" bindinput="onCustomName" />
    </view>
    <view class="modal-field">
      <text class="mf-label">每小时消耗热量（千卡）</text>
      <input class="mf-input" type="digit" placeholder="如：300" value="{{customCal}}" bindinput="onCustomCal" />
    </view>
    <view class="modal-tip">* 热量为参考估算值，实际消耗因人而异</view>
    <view class="modal-btns">
      <view class="mbtn cancel" bindtap="hideModal">取消</view>
      <view class="mbtn ok" bindtap="saveCustom">确定添加</view>
    </view>
  </view>
</view>

</view>
