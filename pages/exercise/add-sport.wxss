/* ==========================================
   pages/exercise/add-sport.wxss
   ========================================== */

   .page {
    --lav:       #ddd0f0;
    --lav-deep:  #7c5cbf;
    --lav-light: #f3eefa;
    --mint:      #c8e6c9;
    --mint-deep: #43a047;
    --bg:        #f5f3ee;
    --card:      #ffffff;
    --txt:       #1a1a2e;
    --txt2:      #9a9aa0;
    --txt3:      #c5c3be;
    --shadow:    0 2rpx 14rpx rgba(0,0,0,0.05);
    --r-sm:      16rpx;
    --r-md:      20rpx;
    --r-lg:      28rpx;
  
    height: 100vh;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  /* ---- 头部 ---- */
  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8rpx 24rpx 8rpx;
    background: #faf9f6;
    flex-shrink: 0;
  }
  
  .back-btn {
    width: 64rpx;
    height: 64rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48rpx;
    color: var(--lav-deep);
    font-weight: 300;
    border-radius: 50%;
    line-height: 1;
  }
  
  .back-btn:active {
    background: var(--lav-light);
  }
  
  .head-title {
    font-size: 34rpx;
    font-weight: 800;
    color: var(--txt);
  }
  
  .head-right {
    width: 64rpx;
  }
  
  /* ---- 搜索栏 ---- */
  .search-wrap {
    padding: 8rpx 28rpx 16rpx;
    flex-shrink: 0;
    background: #faf9f6;
  }
  
  .search-box {
    display: flex;
    align-items: center;
    background: var(--card);
    border-radius: 40rpx;
    padding: 14rpx 28rpx;
    gap: 12rpx;
    box-shadow: var(--shadow);
  }
  
  .s-icon {
    font-size: 28rpx;
    flex-shrink: 0;
  }
  
  .s-input {
    flex: 1;
    font-size: 28rpx;
    color: var(--txt);
  }
  
  .s-placeholder {
    color: var(--txt3);
  }
  
  .s-clear {
    font-size: 26rpx;
    color: var(--txt2);
    padding: 8rpx 4rpx;
    line-height: 1;
  }
  
  /* ---- 内容滚动 ---- */
  .content-scroll {
    flex: 1;
    overflow: hidden;
  }
  
  .content-row {
    flex: 1;
    display: flex;
    overflow: hidden;
  }
  
  .list-pad {
    padding: 16rpx 24rpx 24rpx;
  }
  
  .result-hint {
    font-size: 22rpx;
    color: var(--txt2);
    margin-bottom: 16rpx;
    padding-left: 4rpx;
  }
  
  /* ---- 左侧分类栏 ---- */
  .sidebar {
    width: 172rpx;
    background: #faf9f6;
    flex-shrink: 0;
    border-right: 1rpx solid #eee;
  }
  
  .sb-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24rpx 0;
    gap: 4rpx;
    position: relative;
    transition: background 0.2s;
  }
  
  .sb-item.act {
    background: var(--bg);
  }
  
  .sb-item.act::before {
    content: '';
    position: absolute;
    left: 0;
    top: 18%;
    bottom: 18%;
    width: 6rpx;
    background: var(--lav-deep);
    border-radius: 0 4rpx 4rpx 0;
  }
  
  .sb-ico {
    font-size: 34rpx;
    line-height: 1;
  }
  
  .sb-txt {
    font-size: 20rpx;
    color: var(--txt2);
    font-weight: 500;
  }
  
  .sb-item.act .sb-txt {
    color: var(--lav-deep);
    font-weight: 700;
  }
  
  /* ---- 右侧运动列表 ---- */
  .sport-scroll {
    flex: 1;
    overflow: hidden;
  }
  
  /* ---- 运动卡片 ---- */
  .sport-row {
    display: flex;
    align-items: center;
    gap: 18rpx;
    background: var(--card);
    border-radius: var(--r-md);
    padding: 22rpx;
    margin-bottom: 14rpx;
    box-shadow: var(--shadow);
    border: 3rpx solid transparent;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    position: relative;
  }
  
  .sport-row:active {
    transform: scale(0.98);
  }
  
  .sport-row.sel {
    border-color: var(--lav-deep);
    background: var(--lav-light);
  }
  
  .sr-emoji {
    width: 80rpx;
    height: 80rpx;
    background: var(--lav-light);
    border-radius: var(--r-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40rpx;
    flex-shrink: 0;
    line-height: 1;
  }
  
  .sport-row.sel .sr-emoji {
    background: #e8ddf8;
  }
  
  .sr-info {
    flex: 1;
    min-width: 0;
  }
  
  .sr-name {
    font-size: 27rpx;
    font-weight: 700;
    color: var(--txt);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .sr-meta {
    font-size: 21rpx;
    color: var(--txt2);
    margin-top: 4rpx;
    display: block;
  }
  
  .sport-row.sel .sr-meta {
    color: var(--lav-deep);
  }
  
  /* ---- 单选圆圈 ---- */
  .radio {
    width: 40rpx;
    height: 40rpx;
    border-radius: 50%;
    border: 3rpx solid #ddd;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  
  .radio.on {
    background: var(--lav-deep);
    border-color: var(--lav-deep);
  }
  
  .radio-check {
    font-size: 22rpx;
    color: #fff;
    font-weight: 700;
    line-height: 1;
  }
  
  /* ---- 删除按钮 ---- */
  .del-btn {
    width: 48rpx;
    height: 48rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26rpx;
    color: var(--txt3);
    flex-shrink: 0;
    border-radius: 50%;
    transition: background 0.15s;
  }
  
  .del-btn:active {
    background: #f5f0f0;
  }
  
  /* ---- 添加自定义按钮 ---- */
  .add-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    padding: 28rpx;
    margin-bottom: 14rpx;
    background: var(--card);
    border: 3rpx dashed var(--lav);
    border-radius: var(--r-md);
    color: var(--lav-deep);
    font-size: 27rpx;
    font-weight: 600;
    transition: background 0.15s;
  }
  
  .add-btn:active {
    background: var(--lav-light);
  }
  
  .add-plus {
    font-size: 42rpx;
    font-weight: 300;
    line-height: 1;
  }
  
  /* ---- 空状态 ---- */
  .empty-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 100rpx 0;
    gap: 12rpx;
  }
  
  .empty-ico {
    font-size: 72rpx;
    line-height: 1;
    margin-bottom: 8rpx;
  }
  
  .empty-txt {
    font-size: 28rpx;
    color: var(--txt2);
  }
  
  .empty-sub {
    font-size: 24rpx;
    color: var(--txt3);
    text-align: center;
    padding: 0 40rpx;
  }
  
  /* ===========================
     底部时长面板
     =========================== */
  
  .panel-mask {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 500;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  
  .panel-mask.show {
    opacity: 1;
    pointer-events: auto;
  }
  
  .panel {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    background: var(--card);
    border-radius: 32rpx 32rpx 0 0;
    z-index: 501;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 -6rpx 36rpx rgba(0, 0, 0, 0.08);
    padding-bottom: env(safe-area-inset-bottom);
  }
  
  .panel.show {
    transform: translateY(0);
  }
  
  .panel-handle {
    display: flex;
    justify-content: center;
    padding: 20rpx 0 4rpx;
  }
  
  .handle-bar {
    width: 60rpx;
    height: 8rpx;
    border-radius: 4rpx;
    background: #e0ddd8;
  }
  
  .panel-body {
    padding: 0 36rpx 32rpx;
  }
  
  .ps-row {
    display: flex;
    align-items: center;
    gap: 20rpx;
    padding: 12rpx 0 24rpx;
    border-bottom: 1rpx solid #f0eee8;
    margin-bottom: 24rpx;
  }
  
  .ps-emoji {
    width: 84rpx;
    height: 84rpx;
    background: var(--lav-light);
    border-radius: var(--r-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 44rpx;
    flex-shrink: 0;
    line-height: 1;
  }
  
  .ps-info {
    flex: 1;
  }
  
  .ps-name {
    font-size: 32rpx;
    font-weight: 800;
    color: var(--txt);
    display: block;
  }
  
  .ps-cal {
    font-size: 22rpx;
    color: var(--txt2);
    display: block;
    margin-top: 6rpx;
  }
  
  .panel-label {
    font-size: 26rpx;
    font-weight: 700;
    color: var(--txt);
    display: block;
    margin-bottom: 16rpx;
  }
  
  .dur-presets {
    display: flex;
    flex-wrap: wrap;
    gap: 14rpx;
    margin-bottom: 18rpx;
  }
  
  .dur-pill {
    padding: 14rpx 28rpx;
    border-radius: 36rpx;
    background: #f5f3ee;
    font-size: 26rpx;
    font-weight: 600;
    color: var(--txt2);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .dur-pill.on {
    background: linear-gradient(135deg, var(--lav), var(--lav-deep));
    color: #fff;
    box-shadow: 0 4rpx 16rpx rgba(124, 92, 191, 0.25);
    transform: scale(1.05);
  }
  
  .dur-pill:active {
    transform: scale(0.95);
  }
  
  .dur-input {
    display: flex;
    align-items: center;
    gap: 12rpx;
    background: #faf9f6;
    border-radius: var(--r-md);
    padding: 18rpx 24rpx;
    margin-bottom: 8rpx;
  }
  
  .dur-input-icon {
    font-size: 28rpx;
    flex-shrink: 0;
    line-height: 1;
  }
  
  .dur-input input {
    flex: 1;
    font-size: 28rpx;
    color: var(--txt);
  }
  
  .preview {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8rpx;
    padding: 28rpx 0 20rpx;
    animation: pvFadeUp 0.35s ease forwards;
  }
  
  @keyframes pvFadeUp {
    from { opacity: 0; transform: translateY(12rpx); }
    to   { opacity: 1; transform: translateY(0); }
  }
  
  .pv-label {
    font-size: 26rpx;
    color: var(--txt2);
  }
  
  .pv-cal {
    font-size: 60rpx;
    font-weight: 900;
    color: var(--lav-deep);
    line-height: 1;
  }
  
  .pv-unit {
    font-size: 24rpx;
    color: var(--txt2);
    font-weight: 600;
  }
  
  .save-btn {
    margin-top: 12rpx;
    padding: 28rpx;
    border-radius: 48rpx;
    background: linear-gradient(135deg, var(--lav), var(--lav-deep));
    text-align: center;
    font-size: 30rpx;
    font-weight: 700;
    color: #fff;
    letter-spacing: 2rpx;
    box-shadow: 0 8rpx 24rpx rgba(124, 92, 191, 0.3);
    transition: transform 0.2s;
  }
  
  .save-btn:active {
    transform: scale(0.97);
    box-shadow: 0 4rpx 12rpx rgba(124, 92, 191, 0.2);
  }
  
  /* ===========================
     自定义运动弹窗
     =========================== */
  .modal-mask {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }
  
  .modal {
    width: 620rpx;
    background: var(--card);
    border-radius: var(--r-lg);
    padding: 48rpx 40rpx 40rpx;
    box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  }
  
  .modal-tt {
    font-size: 34rpx;
    font-weight: 800;
    text-align: center;
    display: block;
    margin-bottom: 36rpx;
    color: var(--txt);
  }
  
  .modal-field {
    margin-bottom: 24rpx;
  }
  
  .mf-label {
    font-size: 24rpx;
    color: var(--txt2);
    display: block;
    margin-bottom: 10rpx;
  }
  
  .mf-input {
    padding: 20rpx 24rpx;
    background: var(--bg);
    border-radius: 14rpx;
    font-size: 28rpx;
    color: var(--txt);
    width: 100%;
    box-sizing: border-box;
  }
  
  .modal-tip {
    font-size: 20rpx;
    color: var(--txt3);
    margin-top: -8rpx;
    margin-bottom: 8rpx;
  }
  
  .modal-btns {
    display: flex;
    gap: 16rpx;
    margin-top: 32rpx;
  }
  
  .mbtn {
    flex: 1;
    padding: 24rpx;
    border-radius: 40rpx;
    text-align: center;
    font-size: 28rpx;
    font-weight: 700;
    transition: transform 0.15s;
  }
  
  .mbtn:active {
    transform: scale(0.97);
  }
  
  .mbtn.cancel {
    background: #eee;
    color: var(--txt2);
  }
  
  .mbtn.ok {
    background: linear-gradient(135deg, var(--lav), var(--lav-deep));
    color: #fff;
  }
  /* ★ 时间功能：时间选择器样式 */
.time-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx 0 24rpx;
  gap: 0;
}

.time-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.time-tag {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.time-pick-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  min-width: 200rpx;
  transition: all 0.2s ease;
}

.time-pick-btn.has-val {
  background: #f0f7ff;
  border-color: #6C8EEF;
}

.tpb-icon {
  font-size: 30rpx;
}

.tpb-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 2rpx;
}

.time-pick-btn.has-val .tpb-text {
  color: #6C8EEF;
}

.time-mid {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  margin-top: 32rpx;
}

.time-arrow-line {
  width: 24rpx;
  height: 3rpx;
  background: #ddd;
  border-radius: 2rpx;
}

.time-arrow-icon {
  font-size: 28rpx;
  color: #999;
  margin: 0 4rpx;
}
